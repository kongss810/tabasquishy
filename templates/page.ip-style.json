    "layered_images_with_text_NFDj88": {
      "type": "layered-images-with-text",
      "blocks": {
        "subheading_FFVYwy": {
          "type": "subheading",
          "settings": {
            "text": "Designer Liu × TABASQUISHY®"
          }
        },
        "heading_W8MNmD": {
          "type": "heading",
          "settings": {
            "text": "The Inspiration Behind the Sloth & Koala IP Squishies",
            "marker_style": "style1",
            "heading_size": "h3",
            "marker_color": "#fd6262"
          }
        },
        "text_Jj6GQd": {
          "type": "text",
          "settings": {
            "text": "<p>Internationally acclaimed designer Liu — with past collaborations including Lamborghini and Fendi — brings his expertise to TABASQUISHY® with a vision rooted in calm, comfort, and slow living.<br/><br/>For this creation, Liu drew directly from the natural charm of sloths and koalas — creatures that embody unhurried grace and effortless ease. The result is an IP design that feels instantly recognizable, deeply comforting, and perfectly aligned with our brand’s mission: to create soft spaces in a hard world.<br/><br/>These aren’t just squishies — they’re a tactile reminder to pause, breathe, and embrace life at your own pace.</p>"
          }
        }
      },
      "block_order": [
        "subheading_FFVYwy",
        "heading_W8MNmD",
        "text_Jj6GQd"
      ],
