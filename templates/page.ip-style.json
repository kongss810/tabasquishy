    "rich_text_xcRRWP": {
      "type": "rich-text",
      "blocks": {
        "subheading_gxBWiq": {
          "type": "subheading",
          "settings": {
            "text": "The Story of TABASQUISHY®"
          }
        },
        "heading_babbRX": {
          "type": "heading",
          "settings": {
            "text": "✨ SOFT TO TOUCH, STRONG AT HEART",
            "marker_style": "style1",
            "size": "h3",
            "marker_color": "#fd6262"
          }
        },
        "image_4bBXae": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/tabasquishy_brand_VI.jpg"
          }
        },
        "text_REBVn4": {
          "type": "text",
          "settings": {
            "text": "<p>At TABASQUISHY®, we believe every feeling deserves a soft landing.</p><p>Whether you’re anxious, overstimulated, or just need a break—we’re here to help you squish it out.</p><p>Our brand was born in 2018 from a heartfelt moment between a mother and her child, and has since grown into a global community. But our core belief never changed: <em><strong>It’s okay not to be perfect. What matters is being real.</strong></em></p><p>We design every squishy as a soft space in a hard world—a small, sensory-friendly ritual of comfort and self-expression.</p><p>Each piece is handcrafted, uniquely imperfect, and made to celebrate individuality—just like you.</p><p>TABASQUISHY® is more than play.</p><p>It’s about pausing, breathing, reconnecting with your emotions, and expressing who you are without judgment. Whether you’re a little chaotic, quietly creative, or just looking for calm—we’re here.</p><p>We also believe in giving back. Every purchase supports ADHD awareness, children’s wellness, and environmental initiatives like tree planting and ocean cleanup.</p><p>Because you don’t need to be fixed.</p><p>You just need a squishy.</p>",
            "size": "text-size-regular"
          }
        }
      },
      "block_order": [
        "subheading_gxBWiq",
        "heading_babbRX",
        "image_4bBXae",
        "text_REBVn4"
