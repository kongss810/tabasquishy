                },

                {
                    "type": "header",
                    "content": "Content"
                },

                {
                    "type": "richtext",
                    "id": "title",
                    "label": "Title"
                },

                {
                    "type": "richtext",
                    "id": "content",
                    "label": "Content"
                },

                {
                    "type": "header",
                    "content": "Product Collection"
                },

                {
                    "type": "collection",
                    "id": "collection",
                    "label": "collection"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Influencer Picks",
            "settings": {}
        }
    ]
}
