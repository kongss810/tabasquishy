{%- render 'section-spacing', section: section -%}
<style>
    .influencer_picks_bottom {
        background: {{ section.settings.background }};
    }

    .influencerPicks_avatar img {
        border-radius: 50%;
    }

    .influencerPicks_info_imgBox,
    .influencerPicks_collection {
        display: none;
    }

    .influencerPicks_info_imgBox.active,
    .influencerPicks_collection.active {
        display: block;
    }
</style>
<section>
    <div class='influencer_picks flex flex-col sm:gap-52'>
        {%- if section.settings.title != blank or section.settings.content != blank -%}
            <div class='influencer_picks_top flex flex-col items-center justify-center sm:gap-24'>
                {%- if section.settings.title != blank -%}
                    <h2 class='influencer_picks_title hide_p m-0 text-center font-[600] text-[#1A1A1A] sm:text-[64px] sm:leading-[120%]'>
                        {{ section.settings.title }}
                    </h2>
                {%- endif -%}
                {%- if section.settings.content != blank -%}
                    <div class='influencer_picks_text hide_p text-center font-[400] text-[#333] sm:text-[16px] sm:leading-[150%]'>
                        {{ section.settings.content }}
                    </div>
                {%- endif -%}
            </div>
        {%- endif -%}
        <div class='influencer_picks_bottom relative w-full'>
            {%- if section.settings.img != blank -%}
                <div class='influencer_picks_img absolute top-0 z-0 w-full'>
                    {% render 'section-img', loading: 'eager', img: section.settings.img, width: 1920 %}
                </div>
            {%- endif -%}
            <div class='relative container flex flex-col sm:gap-54'>
                <div class='influencerPicks_info max-w-[1360px] mx-auto sm:px-7.5% flex w-full items-end justify-center sm:gap-80'>
                    <div class='influencerPicks_info_left sm:w-[44%]'>
                        {% for block in section.blocks %}
                            <div
                                class='influencerPicks_info_imgBox'
                                data-index='{{forloop.index0}}'
                            >
                                <div class='influencerPicks_info_img'>
                                    {% render 'section-img', loading: 'lazy', img: block.settings.img, width: 522 %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    <div class='influencerPicks_info_right flex flex-col sm:w-[56%] sm:gap-[52px] sm:pb-[50px] md:gap-[52px] md:pb-[50px]'>
                        <div class='Swiper influencerPicks_swiper w-full overflow-hidden'>
                            <div class='swiper-wrapper'>
                                {% for block in section.blocks %}
                                    <div class='swiper-slide influencerPicks_list flex flex-col sm:gap-[52px] md:gap-[52px]'>
                                        <div class='influencerPicks_listTop flex items-center sm:gap-16'>
                                            <div class='influencerPicks_avatar flex h-80 w-80 items-center justify-center rounded-full'>
                                                {% render 'section-img', loading: 'lazy', img: block.settings.avatar_img, width: 200 %}
                                            </div>
                                            <div class='flex flex-col gap-12'>
                                                <div class='flex items-center sm:gap-16'>
                                                    <div class='text-[24px] leading-[120%] font-[600] text-black'>{{ block.settings.name }}</div>
                                                    {%- if block.settings.link != blank -%}
                                                        <a
                                                            href='{{ block.settings.link }}'
                                                            class='flex items-center text-[16px] leading-[120%] font-[500] text-black/50 uppercase sm:gap-10'
                                                        >
                                                            {{ block.settings.link_text }}
                                                            <svg
                                                                xmlns='http://www.w3.org/2000/svg'
                                                                width='5'
                                                                height='8'
                                                                viewBox='0 0 5 8'
                                                                fill='none'
                                                            >
                                                                <path d="M0.462795 0.00799227C0.522301 0.00735331 0.581301 0.0176892 0.636 0.0383353C0.690699 0.0589814 0.739886 0.0894809 0.780399 0.127872L4.86388 3.72428C5.04537 3.88412 5.04537 4.13187 4.86388 4.29171L0.780399 7.88012C0.598911 8.03996 0.317605 8.03996 0.136117 7.88012C-0.045372 7.72028 -0.045372 7.47253 0.136117 7.31269L3.902 4.004L0.136117 0.687313C-0.045372 0.527473 -0.045372 0.279721 0.136117 0.119881C0.226861 0.0399604 0.344828 0 0.453721 0L0.462795 0.00799227Z" fill="black" fill-opacity="0.5"/>
                                                            </svg>
                                                        </a>
                                                    {%- else -%}
                                                        <div class='flex items-center text-[16px] leading-[120%] font-[500] text-black/50 uppercase sm:gap-10'>
                                                            {{ block.settings.link_text }}
                                                            <svg
                                                                xmlns='http://www.w3.org/2000/svg'
                                                                width='5'
                                                                height='8'
                                                                viewBox='0 0 5 8'
                                                                fill='none'
                                                            >
                                                                <path d="M0.462795 0.00799227C0.522301 0.00735331 0.581301 0.0176892 0.636 0.0383353C0.690699 0.0589814 0.739886 0.0894809 0.780399 0.127872L4.86388 3.72428C5.04537 3.88412 5.04537 4.13187 4.86388 4.29171L0.780399 7.88012C0.598911 8.03996 0.317605 8.03996 0.136117 7.88012C-0.045372 7.72028 -0.045372 7.47253 0.136117 7.31269L3.902 4.004L0.136117 0.687313C-0.045372 0.527473 -0.045372 0.279721 0.136117 0.119881C0.226861 0.0399604 0.344828 0 0.453721 0L0.462795 0.00799227Z" fill="black" fill-opacity="0.5"/>
                                                            </svg>
                                                        </div>
                                                    {%- endif -%}
                                                </div>
                                                <div class='text-[18px] leading-[150%] font-[400] text-[rgba(26,26,26,0.4)]'>
                                                    {{ block.settings.follower_count }} fan
                                                </div>
                                            </div>
                                        </div>
                                        <div class='influencerPicks_listBottom flex flex-col sm:gap-20'>
                                            <div class='hide_p text-[32px] leading-[120%] font-[600] text-black'>{{ block.settings.title }}</div>
                                            <div class='hide_p text-[18px] leading-[150%] font-[400] text-black'>{{ block.settings.content }}</div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                        {% if section.blocks.size > 0 %}
                            <div class='influencer-main-nav flex items-center gap-20 self-stretch'>
                                <div class='my-swiper-button swiper-button-prev static mt-0'>
                                    {%- render 'icon' with 'swiper-prev' -%}
                                </div>
                                <div class='my-swiper-button swiper-button-next static mt-0'>
                                    {%- render 'icon' with 'swiper-next' -%}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
                <div class='w-full'>
                    {% for block in section.blocks %}
                        <div
                            class='influencerPicks_collection w-full'
                            data-index='{{forloop.index0}}'
                        >
                            {%- assign collection = block.settings.collection -%}
                            <div class='Swiper influencerPicks_collection_swiper w-full overflow-hidden'>
                                <div class='swiper-wrapper'>
                                    {% for product in collection.products limit: section.settings.product_limit %}
                                        <div class='swiper-slide'>
                                            {%- render 'product-card-new', product_card_product: product -%}
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                            {% if section.blocks.size > 0 %}
                                <div class='indexCollection_buttons swiper-buttons mt-[52px] flex items-center justify-between gap-[20px]'>
                                    <div class='swiper_buttons_left'>
                                        <div class='swiper-pagination'></div>
                                    </div>
                                    <div class='swiper_buttons_right'>
                                        <div class='swiper-button-prev'>
                                            <svg
                                                xmlns='http://www.w3.org/2000/svg'
                                                width='11'
                                                height='23'
                                                viewBox='0 0 11 23'
                                                fill='none'
                                            >
                                                <path d="M9.67364 2.32616L0.999802 11L9.67364 19.6738" stroke="#161A1F" stroke-opacity="0.6" stroke-width="1.15" stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>
                                        </div>
                                        <div class='swiper-button-next'>
                                            <svg
                                                xmlns='http://www.w3.org/2000/svg'
                                                width='11'
                                                height='23'
                                                viewBox='0 0 11 23'
                                                fill='none'
                                            >
                                                <path d="M1.05973 2.32616L9.73358 11L1.05973 19.6738" stroke="#161A1F" stroke-opacity="0.6" stroke-width="1.15" stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const collectionSwiperMap = {};
        const imageBoxes = document.querySelectorAll('#shopify-section-{{section.id}} .influencerPicks_info_imgBox');
        const collections = document.querySelectorAll('#shopify-section-{{section.id}} .influencerPicks_collection');

        // 批量初始化每个产品轮播
        collections.forEach((item) => {
            const idx = Number(item.dataset.index);
            const swiperWrap = item.querySelector('#shopify-section-{{section.id}} .influencerPicks_collection_swiper');
            const navPrev = item.querySelector('.indexCollection_buttons .swiper-button-prev');
            const navNext = item.querySelector('.indexCollection_buttons .swiper-button-next');
            const navPagination = item.querySelector('.indexCollection_buttons .swiper-pagination');

            const swiper = new Swiper(swiperWrap, {
                observer: true,
                observeParents: true,
                slidesPerView: 4,
                spaceBetween: 24,
                navigation: {
                    nextEl: navNext,
                    prevEl: navPrev,
                },
                pagination: {
                    el: navPagination,
                    type: 'progressbar',
                },
                breakpoints: {
                    0: { slidesPerView: 1.2, spaceBetween: 12 },
                    768: { slidesPerView: 2, spaceBetween: 16 },
                    1024: { slidesPerView: 4, spaceBetween: 24 },
                },
            });
            collectionSwiperMap[idx] = swiper;
        });

        // 切换内容+刷新swiper
        function updateInfluencerContent(activeIndex) {
            imageBoxes.forEach((box) => {
                const i = Number(box.dataset.index);
                box.classList.toggle('active', i === activeIndex);
            });
            collections.forEach((col) => {
                const i = Number(col.dataset.index);
                const isActive = i === activeIndex;
                col.classList.toggle('active', isActive);
                if (isActive && collectionSwiperMap[i]) {
                    collectionSwiperMap[i].update();
                }
            });
        }

        const influencerPicksSwiper = new Swiper('.influencerPicks_swiper', {
            observer: true,
            observeParents: true,
            slidesPerView: 1,
            spaceBetween: 10,
            navigation: {
                nextEl: '.influencer-main-nav .swiper-button-next',
                prevEl: '.influencer-main-nav .swiper-button-prev',
            },
            on: {
                init() {
                    updateInfluencerContent(this.realIndex);
                },
                // ✅ 加上这个
                slideChange() {
                    updateInfluencerContent(this.realIndex);
                },
            },
        });
    });
</script>
