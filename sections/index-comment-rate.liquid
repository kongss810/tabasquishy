                                                                </g>
                                                            </svg>
                                                            <span class='product-card--add-to-cart-text'></span>
                                                        </button>
                                                    {% else %}
                                                        <button
                                                            class='sold_out_btn cursor-not-allowed opacity-50'
                                                            disabled
                                                            data-id='{{ block.settings.product.first_available_variant.id }}'
                                                        >
                                                            <svg
                                                                width='48'
                                                                height='48'
                                                                viewBox='0 0 48 48'
                                                                fill='none'
                                                                xmlns='http://www.w3.org/2000/svg'
                                                            >
                                                                <rect width="48" height="48" rx="24" fill="#FCD454"/>
                                                                <mask id="mask0_680_3975" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="12" y="12" width="24" height="24">
                                                                <rect x="12" y="12" width="24" height="24" fill="#D9D9D9"/>
                                                                </mask>
                                                                <g mask="url(#mask0_680_3975)">
                                                                <path d="M15.9029 34.5C15.3711 34.5 14.9211 34.3158 14.5526 33.9474C14.1842 33.5789 14 33.1289 14 32.5971V20.6134C14 20.0817 14.1842 19.6316 14.5526 19.2632C14.9211 18.8947 15.3711 18.7105 15.9029 18.7105H20.0526V16.4474C20.0526 15.357 20.4379 14.4265 21.2084 13.6558C21.9791 12.8853 22.9096 12.5 24 12.5C25.0904 12.5 26.0209 12.8853 26.7916 13.6558C27.5621 14.4265 27.9474 15.357 27.9474 16.4474V18.7105H32.0971C32.6289 18.7105 33.0789 18.8947 33.4474 19.2632C33.8158 19.6316 34 20.0817 34 20.6134V32.5971C34 33.1289 33.8158 33.5789 33.4474 33.9474C33.0789 34.3158 32.6289 34.5 32.0971 34.5H15.9029ZM15.9029 32.9211H32.0971C32.1782 32.9211 32.2524 32.8873 32.3197 32.8197C32.3873 32.7524 32.4211 32.6782 32.4211 32.5971V20.6134C32.4211 20.5324 32.3873 20.4582 32.3197 20.3908C32.2524 20.3232 32.1782 20.2895 32.0971 20.2895H27.9474V22.6579C27.9474 22.8819 27.8718 23.0695 27.7205 23.2205C27.5695 23.3718 27.3819 23.4474 27.1579 23.4474C26.9339 23.4474 26.7463 23.3718 26.5953 23.2205C26.444 23.0695 26.3684 22.8819 26.3684 22.6579V20.2895H21.6316V22.6579C21.6316 22.8819 21.556 23.0695 21.4047 23.2205C21.2537 23.3718 21.0661 23.4474 20.8421 23.4474C20.6181 23.4474 20.4305 23.3718 20.2795 23.2205C20.1282 23.0695 20.0526 22.8819 20.0526 22.6579V20.2895H15.9029C15.8218 20.2895 15.7476 20.3232 15.6803 20.3908C15.6127 20.4582 15.5789 20.5324 15.5789 20.6134V32.5971C15.5789 32.6782 15.6127 32.7524 15.6803 32.8197C15.7476 32.8873 15.8218 32.9211 15.9029 32.9211ZM21.6316 18.7105H26.3684V16.4474C26.3684 15.7875 26.1387 15.2278 25.6792 14.7682C25.2197 14.3087 24.66 14.0789 24 14.0789C23.34 14.0789 22.7803 14.3087 22.3208 14.7682C21.8613 15.2278 21.6316 15.7875 21.6316 16.4474V18.7105Z" fill="#1A1A1A"/>
                                                                </g>
                                                            </svg>
                                                        </button>
                                                    {% endif %}
                                                </product-card>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                    <div
                                        class='comment-rate-text-content'
                                        {% if block.settings.block_bg %}
                                            style='background-image: url({{ block.settings.block_bg | image_url: width: 1920 }}); background-color: {{ block.settings.bg_color }}'
                                        {% endif %}
                                    >
                                        <div class='comment-rate-content-header'>
                                            {% if block.settings.block_title != blank %}
                                                <div class='comment-rate-content-title'>{{ block.settings.block_title }}</div>
                                            {% endif %}
                                            {% if block.settings.block_text != blank %}
                                                <div class='comment-rate-content-text'>{{ block.settings.block_text }}</div>
                                            {% endif %}
                                        </div>
                                        <div class='comment-rate-profile-rate'>
                                            <div class='comment-rate-profile-rate-left'>
                                                {% if block.settings.avatar != blank %}
                                                    <div class='comment-rate-profile-rate-left-avatar'>
                                                        {% render 'section-img', img: block.settings.avatar, width: 220, mobile_width: 220, loading: 'eager' %}
                                                    </div>
                                                {% endif %}
                                                <div class='comment-rate-profile-rate-left-content'>
                                                    {% if block.settings.block_rate_title != blank %}
                                                        <div class='comment-rate-profile-rate-left-content-title'>{{ block.settings.block_rate_title }}</div>
                                                    {% endif %}
                                                    {% if block.settings.block_rate_confirm != blank %}
                                                        <div class='comment-rate-profile-rate-left-content-confirm'>
                                                            {{ block.settings.block_rate_confirm }}
                                                        </div>
                                                    {% endif %}
                                                </div>
                                            </div>
                                            {%- if block.settings.rating != blank -%}
                                                <div class='comment-rate-profile-rate-right'>
                                                    {% render 'section-img', img: block.settings.rating, width: 220, mobile_width: 220, loading: 'eager' %}
                                                </div>
                                            {%- endif -%}
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        <span
                            class='swiper-notification'
                            aria-live='assertive'
                            aria-atomic='true'
                        ></span>
                    </div>
                </div>
            </div>
            {% if section.blocks.size > 0 %}
                <div class='indexCollection_buttons swiper-buttons mt-[52px] flex items-center justify-between gap-[20px]'>
                    <div class='swiper_buttons_left'>
                        <div class='swiper-pagination'></div>
                    </div>
                    <div class='swiper_buttons_right'>
                        <div class='swiper-button-prev'>
                            <svg
                                xmlns='http://www.w3.org/2000/svg'
                                width='11'
                                height='23'
                                viewBox='0 0 11 23'
                                fill='none'
                            >
                                <path d="M9.67364 2.32616L0.999802 11L9.67364 19.6738" stroke="#161A1F" stroke-opacity="0.6" stroke-width="1.15" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class='swiper-button-next'>
                            <svg
                                xmlns='http://www.w3.org/2000/svg'
                                width='11'
                                height='23'
                                viewBox='0 0 11 23'
                                fill='none'
                            >
                                <path d="M1.05973 2.32616L9.73358 11L1.05973 19.6738" stroke="#161A1F" stroke-opacity="0.6" stroke-width="1.15" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var swipertext = new Swiper(`#shopify-section-{{section.id}} .swiper-all_program`, {
            navigation: {
                nextEl: '#shopify-section-{{section.id}} .swiper-button-next',
                prevEl: '#shopify-section-{{section.id}} .swiper-button-prev',
            },
            mousewheel: {
                forceToAxis: true,
            },
            pagination: {
                el: '#shopify-section-{{section.id}} .swiper-pagination',
                type: 'progressbar',
            },
            breakpoints: {
                300: { slidesPerView: 1, spaceBetween: 30 },
                1280: { slidesPerView: 1.27, spaceBetween: 60 },
            },
            on: {
                init() {
                    updateActiveClass(this);
                },
                slideChange() {
                    updateActiveClass(this);
                },
                transitionEnd() {
                    updateActiveClass(this);
                },
            },
        });

        function updateActiveClass(swiper) {
            const allSlides = swiper.el.querySelectorAll('.swiper-slide');

            // 清除所有自定义类
            allSlides.forEach((slide) => {
                slide.classList.remove('active', 'is-last-active');
            });

            const { activeIndex, params, isEnd } = swiper;

            if (isEnd || activeIndex + params.slidesPerView >= allSlides.length) {
                // 末尾状态：只给最后一张加 is-last-active
                allSlides[allSlides.length - 1].classList.add('is-last-active');
            } else {
                // 正常状态：给当前 activeIndex 的 slide 加 active
                if (allSlides[activeIndex]) {
                    allSlides[activeIndex].classList.add('active');
                }
            }
        }
    });
</script>

{% schema %}
{
    "name": "Index Comment Rate",
    "class": "css-layout",
    "settings": [
        {
            "type": "richtext",
            "id": "title",
            "label": "title"
        },
        {
            "type": "header",
            "content": "Highlighted text",
            "info": "To add an animated highlight to text, simply wrap it in italics. Click the I button in the editor to toggle italics when highlighting text."
        },
        {
            "type": "select",
            "id": "highlighted_text",
            "options": [
                {
                    "value": "none",
                    "label": "None"
                },
                {
                    "value": "scribble",
                    "label": "Hand-drawn scribble"
                }
            ],
            "default": "none",
            "label": "Highlighted text"
        },
        {
            "type": "header",
            "content": "Spacing Top:"
        },
        {
            "type": "number",
            "id": "Desktop_paddingTop",
            "label": "Desktop Padding Top",
            "default": 0
        },
        {
            "type": "number",
            "id": "Mobile_paddingTop",
            "label": "Mobile Padding Top",
            "default": 0
        },
        {
            "type": "header",
            "content": "Spacing Bottom:"
        },
        {
            "type": "number",
            "id": "Desktop_paddingBottom",
            "label": "Desktop Padding Bottom",
            "default": 0
        },
        {
            "type": "number",
            "id": "Mobile_paddingBottom",
            "label": "Mobile Padding Bottom",
            "default": 0
        }
    ],
    "blocks": [
