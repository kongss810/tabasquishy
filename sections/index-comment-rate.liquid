{%- render 'section-spacing', section: section -%}

<style>
    .IndexCommentRate_all {
        overflow: hidden;
    }
    .swiper-all_program {
        overflow: unset;
    }
    .comment-rate-header-left-side {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 20px;
    }

    .comment-rate-header-right-side {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .comment-rate-title {
        color: #1a1a1a;
        text-align: center;
        font-size: 64px;
        font-weight: 600;
        line-height: 120%; /* 76.8px */

        max-width: 900px;
    }

    .comment-rate-description {
        font-size: 16px;
        font-weight: 400;
        line-height: 150%; /* 24px */
    }

    .comment-rate-view-text {
        /* 按钮 */
        font-size: 16px;
        font-weight: 500;
        line-height: 120%; /* 19.2px */
    }

    .comment-rate-card {
        display: flex;
        align-items: stretch;
        border-radius: 15px;
    }

    .comment-rate-text-content {
        display: flex;
        padding: 60px 40px;
        flex-direction: column;
        justify-content: space-between;
        align-items: start;
        background: #fffbee;
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
        height: auto;
        min-height: 100%;
        width: 100%;
        gap: 40px;
    }

    .comment-rate-text-content p {
        margin: 0;
        line-height: 120%;
    }

    .comment-rate-text-content-left {
        display: flex;
        width: 62.21%;
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
    }

    .comment-rate-text-content-right {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        height: 100%;
    }

    .comment-rate-text-block-title {
        font-size: 24px;
        font-weight: 600;
        line-height: 120%; /* 28.8px */
        letter-spacing: -0.24px;
    }

    .comment-rate-text-block-description {
        font-size: 16px;
        font-weight: 400;
        line-height: 150%; /* 24px */
    }

    .comment-rate-text-block-button {
        display: flex;
        padding: 12px 48px;
        justify-content: center;
        align-items: center;
        gap: 10px;
        border-radius: 999px;
        background: #fdd554;
    }

    .comment-rate-text-block-button p {
        display: flex;
        font-size: 16px;
        font-style: normal;
        font-weight: 500;
        line-height: 120%; /* 19.2px */
    }

    .comment-rate-text-block-price {
        display: flex;
        padding: 0 12px;
        justify-content: center;
        align-items: flex-start;
        gap: 10px;
        font-size: 24px;

        font-weight: 600;
    }

    .comment-rate-content-header {
        gap: 60px;
        display: flex;
        flex-direction: column;
    }

    .comment-rate-profile-rate {
        display: flex;
        justify-content: space-between;
        align-items: center;
        align-self: stretch;
    }

    .comment-rate-profile-rate-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .comment-rate-profile-rate-left-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        gap: 12px;
    }

    .comment-rate-content-title {
        color: #1a1a1a;
        font-size: 16px;
        font-weight: 400;
        line-height: 120%; /* 19.2px */
    }

    .comment-rate-content-text {
        color: #1a1a1a;
        font-size: 36px;
        font-weight: 500;
        line-height: 100%;
    }

    .comment-rate-profile-rate-left-content-title {
        color: #1a1a1a;
        font-size: 20px;
        font-weight: 600;
    }

    .comment-rate-profile-rate-left-content-confirm {
        color: rgba(26, 26, 26, 0.4);
        font-size: 18px;
        font-weight: 400;
    }

    .comment-rate-media {
        width: 38.66%;
    }

    .comment-rate-media img {
        object-fit: cover;
        height: 100%;
    }

    .comment-rate-text-content {
        width: 61.34%;
    }
    .comment-rate-media.media {
        position: relative;
    }

    .comment-rate-media.media product-card {
        position: absolute;
        bottom: 32px;
        left: 0;
        right: 0;
        margin: 0 32px;
        background-color: #ffffff;
    }

    .product-left-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .product-left-info .product-img-box {
        flex-shrink: 0;
        width: 80px;
        height: 80px;
    }
    .product-left-info .product-img-box img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }
    .product-info-box .title {
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
        color: var(--my-title);
    }

    .IndexCommentRate_all .index-media-item .product-box .add-cart-btn {
        position: relative;
        cursor: pointer;
        display: flex;
        margin-top: 0;
        width: 48px;
        height: 48px;
        border-radius: 50%;
    }
    .IndexCommentRate_all .index-media-item .product-box .sold_out_btn {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .comment-rate-profile-rate-left-avatar {
        min-width: 80px;
        width: 80px;
        border-radius: 50%;
        overflow: hidden;
        height: 80px;
    }

    .comment-rate-profile-rate-right {
        flex-wrap: nowrap;
        display: flex;
        gap: 4px;
    }
    .comment-rate-profile-rate-right img {
        object-fit: contain;
    }
    .comment-rate-card {
        border-radius: 15px;
        overflow: hidden;
    }

    .IndexCommentRate_all .my_picture {
        height: 100%;
    }

    .IndexCommentRate_all .swiper-slide {
        opacity: 0.3;
        transition: opacity 800ms ease;
    }

    /* 用自定义 active 替代 swiper-slide-active */
    .IndexCommentRate_all .swiper-slide.active {
        opacity: 1;
    }

    .IndexCommentRate_all .swiper-slide.is-last-active {
        opacity: 1;
    }
</style>

<div class='IndexCommentRate_all'>
    <div class='container'>
        {% if section.settings.title != blank %}
            <div class='comment-rate-header mb-[52px] flex items-center justify-center gap-[20px] text-center'>
                {% if section.settings.title != blank %}
                    {%- if section.settings.highlighted_text == 'none' -%}
                        <h2 class='header-title text-title hide_p text-[28px] leading-[113%] font-[600] tracking-[0] sm:text-[64px] sm:leading-[120%]'>
                            {{ section.settings.title }}
                        </h2>
                    {%- else -%}
                        {%- render 'highlighted-text',
                            class: 'header-title text-title hide_p text-[28px] sm:text-[64px] font-[600] sm:leading-[120%] leading-[113%] tracking-[0]',
                            content: section.settings.title,
                            style: section.settings.highlighted_text,
                            scribble: 'sketch-underline',
                            gradient: with_gradient
                        -%}
                    {%- endif -%}
                {% endif %}
            </div>
        {% endif %}

        <div class='comment-rate-container'>
            <div class='comment-rate-content'>
                <div class='swiper-father'>
                    <div class='swiper swiper-all_program'>
                        <div
                            class='swiper-wrapper'
                        >
                            {% for block in section.blocks %}
                                <div
                                    class='swiper-slide comment-rate-card'
                                >
                                    {% if block.settings.image %}
                                        <div class='comment-rate-media media img_hover'>
                                            {% render 'section-img',
                                                img: block.settings.image,
                                                img_mobile: block.settings.image,
                                                width: 1000,
                                                mobile_width: 750,
                                                loading: 'lazy',
                                                class: ''
                                            %}

                                            {% if block.settings.product != blank %}
                                                <product-card
                                                    style="background-image: url('https://cdn.shopify.com/s/files/1/0606/0690/6412/files/Vector_6.png?v=1779418964');"
                                                    class="product-box mt-[16px] flex h-[104px] items-center justify-between gap-[12px] overflow-hidden rounded-[15px] border border-[rgba(26,26,26,0.2)] bg-[url('https://cdn.shopify.com/s/files/1/0606/0690/6412/files/Vector_6.png?v=1779418964')] bg-cover bg-center bg-no-repeat p-[12px]"
                                                >
                                                    <a
                                                        class='product-left-info flex items-center gap-[12px]'
                                                        href='{{ block.settings.product.url }}'
                                                    >
                                                        <div class='product-img-box h-[80px] w-[80px] flex-shrink-0'>
                                                            <img
                                                                class='img h-full w-full object-contain'
                                                                loading='lazy'
                                                                width='auto'
                                                                height='auto'
                                                                src='{{ block.settings.product.featured_media | image_url }}'
                                                            >
                                                        </div>
                                                        <div class='product-info-box'>
                                                            <div class='title line-clamp-2 text-[16px] leading-[113%] font-[400] tracking-[-1%] sm:leading-[120%]'>
                                                                {{ block.settings.product.title }}
                                                            </div>
                                                            <span class='price mt-[12px] text-[16px] leading-[113%] font-[600] tracking-[-4%] sm:leading-[100%]'>
                                                                {{ block.settings.product.price | money }}
                                                            </span>
                                                        </div>
                                                    </a>
                                                    {% if block.settings.product.selected_or_first_available_variant.available %}
                                                        <button
                                                            class='add-cart-btn product-card--add-to-cart-button product-card--add-to-cart-button-simple relative mt-[0px] flex h-[48px] w-[48px] flex-shrink-0 cursor-pointer overflow-hidden rounded-[50%] bg-[#FCD454]'
                                                            data-product-id='{{ block.settings.product.first_available_variant.id }}'
                                                        >
                                                            {% render 'svg-icons' with 'thb-loading' %}
                                                            <svg
                                                                class='cart-icon'
                                                                width='48'
                                                                height='48'
                                                                viewBox='0 0 48 48'
                                                                fill='none'
                                                                xmlns='http://www.w3.org/2000/svg'
                                                            >
                                                                <rect width="48" height="48" rx="24" fill="#FCD454"/>
                                                                <mask id="mask0_680_3975" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="12" y="12" width="24" height="24">
                                                                <rect x="12" y="12" width="24" height="24" fill="#D9D9D9"/>
                                                                </mask>
                                                                <g mask="url(#mask0_680_3975)">
