{%- liquid
    assign copyright_text = section.settings.copyright_text
    assign show_language_switcher = section.settings.show_language_switcher
    assign show_currency_switcher = section.settings.show_currency_switcher
    assign show_payment_icons = section.settings.show_payment_icons
    assign footer_reveal_animation = section.settings.footer_reveal_animation
-%}

<style>
    .footer_videoBg {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        top: 0;
    }
    .footer_videoBg video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top;
    }
    .footer.footer-container {
        position: relative;
        padding-top: 0;
        padding-bottom: 0;
    }
    .footer .footer-content {
        gap: 20px;
    }
    .footer .widget--text .rte {
        font-weight: 400;
        font-size: 16px;
        line-height: 150%;
        letter-spacing: 0%;
    }
    .footer .widget--text .rte p {
        margin-bottom: 16px;
        font-size: 16px;
    }
    .row.footer-content {
        margin-top: 32.5px;
        padding-top: 260px;
        padding-bottom: 60px;
        padding-left: 40px;
        padding-right: 40px;
        justify-content: space-between;
        position: relative;
    }

    /* 用伪元素画虚线，并限制宽度 */
    .row.footer-content::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 40px; /* 与 padding-left 对齐 */
        right: 40px; /* 与 padding-right 对齐 */
        height: 1px;
        background: linear-gradient(to right, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.5) 10px, transparent 10px, transparent 20px);
        background-size: 18px 1px;
        background-repeat: repeat-x;
    }
    .footer-menu-container {
        gap: 16px;
        display: flex;
        flex-direction: column;
    }

    .footer .thb-widget-menu li {
        margin: 0;
    }

    .footer .thb-widget-menu {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .footer .thb-widget-title.collapsible {
        font-size: 16px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .footer a {
        color: #333;
        font-size: 16px;
        font-weight: 400;
        line-height: 150%; /* 24px */
    }

    .footer-info {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 32px;
        width: 28.75%;
    }

    .footer-social .social-links {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .footer-info .widget.widget--social {
        margin-bottom: 0;
    }

    .row .footer-social .columns {
        padding: 0;
    }

    .footer-social .social-links li {
        margin-bottom: 0;
        display: flex;
        width: 48px;
        height: 48px;
        padding: 3px 11px;
        justify-content: center;
        align-items: center;
        gap: 10px;
        aspect-ratio: 1/1;
        border-radius: 999px;
        background: #fff;
    }

    .footer-title p {
        font-size: 48px;
        font-weight: 600;
        line-height: 120%; /* 57.6px */
        margin: 0;
        font-family: 'Prompt';
    }

    .footer .footer-menu-title.thb-widget-title {
        font-weight: 600;
        font-size: 16px;
        line-height: 100%;
        letter-spacing: 0%;
        text-transform: uppercase;
    }

    .footer .footer-menu-item a {
        font-weight: 400;
        font-size: 16px;
        line-height: 150%;
        letter-spacing: 0%;
    }

    .footer .footer-signup .signup-container input {
        font-weight: 400;
        font-size: 16px;
        line-height: 150%;
        letter-spacing: 0%;
        color: #0000004d;
        background-color: #ffffff99;
        border-color: transparent;
        border-radius: 999px;
        display: flex;
        height: 43px;
        padding: 0 16px;
        align-items: center;
    }

    .widget--signup .field {
        width: 68.91%;
    }

    .footer .footer-signup .signup-container .field label {
        font-weight: 400;
        font-size: 16px;
        line-height: 150%;
        letter-spacing: 0%;
        color: #0000004d;
        height: 100%;
        padding: 9.5px 16px;
    }

    .footer-info-description {
        font-weight: 400;
        font-size: 16px;
        line-height: 150%;
        letter-spacing: 0%;
        margin: 0;
    }

    .footer-info-description p {
        margin: 0;
    }

    .footer-signup {
        display: flex;
        flex-direction: column;
        gap: 12px;
        width: 100%;
    }

    .footer-signup .signup-container fieldset {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        align-self: stretch;
        position: static;
    }

    .footer .footer-signup .signup-container button {
        border-radius: 999px;
        border: 1px solid #000;
        background: #000;
        display: flex;
        width: 131px;
        height: 43px;
        padding: 0 16px;
        justify-content: center;
        align-items: center;
        color: #fff;
        font-size: 16px;
        font-weight: 400;
        line-height: 150%; /* 24px */
        position: static;
    }

    .footer .social-links svg {
        width: auto;
        height: auto;
    }

    .footer.footer-container .sub-footer {
        margin: 0 auto;
        padding: 32px 0;
    }

    .sub-footer-container {
        display: grid;
        gap: 20px;
        grid-template-columns: 1fr auto 1fr;
    }

    .footer .sub-footer .custom-select--button {
        text-align: center;
        font-size: 16px;
        font-weight: 500;
        text-decoration-line: underline;
        text-decoration-style: solid;
        text-decoration-skip-ink: auto;
        text-decoration-thickness: auto;
        text-underline-offset: auto;
        text-underline-position: from-font;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 16px;
        padding: 0;
    }

    .footer .sub-footer .custom-select--arrow {
        fill: #333;

        margin: 0;
    }

    .footer .sub-footer .custom-select--arrow svg path {
        stroke: #333;
    }

    .sub-footer-copyright {
        color: #333;
        font-size: 16px;
        font-weight: 400;
    }

    .sub-footer-copyright p {
        margin: 0;
    }

    .sub-footer-payment-icon-container .footer-payment-icons {
        padding: 0;
        gap: 5px;
        justify-content: flex-end;
        display: flex;
        flex-wrap: wrap;
    }
    .footer-payment-icons figure {
        margin-left: 0 !important;
    }
    .footer-payment-icons figure,
    .footer-payment-icons svg {
        display: block;
    }

    .footer-payment-icons {
        line-height: 0;
    }

    .top-section img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: cover; /* 可选：裁剪适配 */
    }

    .footer.footer-container {
        padding-top: 0;
        padding-bottom: 0;
    }
    .sub-footer {
        position: relative;
        z-index: 2px;
    }
    .footer .sub-footer .social-links svg path {
        fill: #1a1a1a;
    }

    .footer .footer-content .social-links svg path {
        fill: #1a1a1a;
    }

    .footer .signup-container input:focus + label {
        display: none;
    }

    .footer .footer-signup .signup-container input::placeholder {
        color: rgba(0, 0, 0, 0.3);
    }

    .sub-footer .sub-footer-copyright p {
        opacity: 1;
    }
</style>

<link
    rel='stylesheet'
    href='{{ 'footer.css' | asset_url }}'
    media='print'
    onload="this.media='all'"
>
<noscript>{{ 'footer.css' | asset_url | stylesheet_tag }}</noscript>

<theme-footer
    class='footer footer-container'
    id='footer'
>
    {% if section.settings.video != blank %}
        <div class='footer_videoBg'>
            {%- assign poster_url = section.settings.video.preview_image | image_url: width: 1920 -%}

            {{- section.settings.video | video_tag: autoplay: true, playsinline: true, muted: true, loop: true, poster: poster_url -}}
        </div>
    {% endif %}
    <div class='row footer-content container'>
        {%- for block in section.blocks -%}
            {% if block.type == 'text' %}
                {%- liquid
                    assign column_class = 'small-12 medium-4 large-2'
                    case block.settings.column_size
                        when 'medium'
                            assign column_class = 'small-12 medium-3'
                        when 'large'
                            assign column_class = 'small-12 medium-4'
                    endcase
                -%}
                <div
                    class='{{ column_class | escape }}'
                    {{ block.shopify_attributes }}
                >
                    <div class='widget widget--text text-{{ block.settings.text_alignment }}'>
                        {%- if block.settings.title != blank -%}
                            <div class='thb-widget-title'>{{ block.settings.title }}</div>
                        {%- endif -%}
                        {%- if block.settings.image != blank -%}
                            {% assign image = block.settings.image %}
                            {% assign master_width = image.src.width | append: 'x' | append: image.src.height %}
                            {%- render 'responsive-image', image: image, sizes: master_width, retina: 1 -%}
                        {%- endif -%}
                        {%- if block.settings.text != blank -%}
                            <div class='rte text-size--{{ block.settings.text_size }}'>
                                {{ block.settings.text }}
                            </div>
                        {%- endif -%}
                        {%- if block.settings.button_text != blank -%}
                            {% render 'text-button', url: block.settings.button_link, title: block.settings.button_text %}
                        {%- endif -%}
                        {%- if block.settings.show_social_links -%}
                            {%- render 'social-links', show_label: false -%}
                        {%- endif -%}
                    </div>
                </div>
            {% endif %}
            {%- if block.type == 'menu' -%}
                <div
                    class='{{ column_class | escape }}'
                    {{ block.shopify_attributes }}
                >
                    <div class='widget widget--menu footer-menu-container'>
                        <button
                            class='thb-widget-title collapsible footer-menu-title'
                            tabindex='0'
                        >
                            {{ block.settings.title }}
                            <span>{%- render 'svg-icons' with 'thb-collapsible-arrow' -%}</span>
                        </button>
                        {%- if block.settings.menu != blank -%}
                            <ul class='thb-widget-menu'>
                                {% for link in block.settings.menu.links %}
                                    {% assign has_sub_menu = false %}
                                    {% if link.links.size > 0 %}
                                        {% assign has_sub_menu = true %}
                                    {% endif %}
                                    <li class='footer-menu-item {% if has_sub_menu %}menu-item-has-children{% endif %}{% if link.active %} active{% endif %}'>
                                        <a
                                            href='{{ link.url }}'
                                            title='{{ link.title | escape }}'
                                            {%- if link.active %}
                                                aria-current='page'
                                            {% endif -%}
                                        >
                                            {{- link.title -}}
                                        </a>
                                        {%- if has_sub_menu -%}
                                            <span
                                                class='thb-arrow'
                                                tabindex='0'
                                            >
                                                {%- render 'svg-icons' with 'thb-dropdown-bottom' -%}
                                            </span>
                                        {%- endif %}
                                        {% if has_sub_menu %}
                                            <ul
                                                class='sub-menu'
                                                tabindex='-1'
                                            >
                                                {% for l in link.links %}
                                                    {% assign has_sub_menu = false %}
                                                    {% if l.links.size > 0 %}
                                                        {% assign has_sub_menu = true %}
                                                    {% endif %}
                                                    <li
                                                        class='{% if has_sub_menu %}menu-item-has-children{% endif %}{% if l.active %} active{% endif %}'
                                                        role='none'
                                                    >
                                                        <a
                                                            href='{{ l.url }}'
                                                            title='{{ l.title | escape }}'
                                                            role='menuitem'
                                                        >
                                                            {{ l.title }}
                                                        </a>
                                                        {%- if has_sub_menu -%}
                                                            <span
                                                                class='thb-arrow'
                                                                tabindex='0'
                                                            >
                                                                {%- render 'svg-icons' with 'thb-dropdown-bottom' -%}
                                                            </span>
                                                        {%- endif %}
                                                        {% if has_sub_menu %}
                                                            <ul
                                                                class='sub-menu'
                                                                role='menu'
                                                            >
                                                                {% for sub_link in l.links %}
                                                                    {% assign has_sub_menu = false %}
                                                                    {% if sub_link.links.size > 0 %}
                                                                        {% assign has_sub_menu = true %}
                                                                    {% endif %}
                                                                    <li
                                                                        class='{% if has_sub_menu %}menu-item-has-children{% endif %}{% if sub_link.active %} active{% endif %}'
                                                                        role='none'
                                                                    >
                                                                        <a
                                                                            href='{{ sub_link.url }}'
                                                                            title='{{ sub_link.title | escape }}'
                                                                            role='menuitem'
                                                                        >
                                                                            {{- sub_link.title -}}
                                                                        </a>
                                                                    </li>
                                                                {% endfor %}
                                                            </ul>
                                                        {% endif %}
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        {% endif %}
                                    </li>
                                {% endfor %}
                            </ul>
                        {%- endif -%}
                    </div>
                </div>
            {%- endif -%}
            {%- if block.type == 'info' -%}
                <div class='footer-info'>
                    <div class='footer-title'>{{ block.settings.info_title }}</div>
                    <div class='footer-social'>
                        <div
                            class='{{ column_class | escape }} columns'
                            {{ block.shopify_attributes }}
                        >
                            <div class='widget widget--social'>
                                {% if block.settings.title != blank %}
                                    <div class='thb-widget-title'>{{ block.settings.title }}</div>
                                {% endif %}
                                {% render 'social-links', show_label: false %}
                            </div>
                        </div>
                    </div>
                    <div class='footer-signup'>
                        <div class='widget--signup'>
                            {% if block.settings.title != blank %}
                                <div class='thb-widget-title'>{{ block.settings.title }}</div>
                            {% endif %}
                            {% if block.settings.text != blank %}
                                {{ block.settings.text }}
                            {% endif %}
                            {% render 'email-signup-form', text: block.settings.info_button_text %}
                        </div>
                        <div class='footer-info-description'>{{ block.settings.info_description }}</div>
                    </div>
                </div>
            {%- endif -%}
            {%- if block.type == 'signup' -%}
                {%- liquid
                    assign column_class = 'small-12 medium-4 large-2'
                    case block.settings.column_size
                        when 'medium'
                            assign column_class = 'small-12 medium-3'
                        when 'large'
                            assign column_class = 'small-12 medium-4'
                    endcase
                -%}
                <div
                    class='{{ column_class | escape }} columns'
                    {{ block.shopify_attributes }}
                >
                    <div class='widget widget--signup'>
                        {% if block.settings.title != blank %}
                            <div class='thb-widget-title'>{{ block.settings.title }}</div>
                        {% endif %}
                        {% if block.settings.text != blank %}
                            {{ block.settings.text }}
                        {% endif %}
                        {% render 'email-signup-form' %}
                    </div>
                </div>
            {%- endif -%}
            {%- if block.type == 'social' -%}
                {%- liquid
                    assign column_class = 'small-6 medium-4 large-2'
                    case block.settings.column_size
                        when 'medium'
                            assign column_class = 'small-12 medium-3'
                        when 'large'
                            assign column_class = 'small-12 medium-4'
                    endcase
                -%}
                <div
                    class='{{ column_class | escape }} columns'
                    {{ block.shopify_attributes }}
                >
                    <div class='widget widget--social'>
                        {% if block.settings.title != blank %}
                            <div class='thb-widget-title'>{{ block.settings.title }}</div>
                        {% endif %}
                        {% render 'social-links', show_label: true %}
                    </div>
                </div>
            {%- endif -%}
            {%- if block.type == 'custom_liquid' -%}
                {%- liquid
                    assign column_class = 'small-6 medium-4 large-2'
                    case block.settings.column_size
                        when 'medium'
                            assign column_class = 'small-12 medium-3'
                        when 'large'
                            assign column_class = 'small-12 medium-6'
                    endcase
                -%}
                <div
                    class='{{ column_class | escape }} columns'
                    {{ block.shopify_attributes }}
                >
                    <div class='widget widget--custom'>
                        {% if block.settings.title != blank %}
                            <div class='thb-widget-title'>{{ block.settings.title }}</div>
                        {% endif %}
                        {{ block.settings.custom_liquid }}
                    </div>
                </div>
            {%- endif -%}
        {%- endfor -%}
    </div>
    <div class='sub-footer container'>
        <div class='row sub-footer-container container'>
            <div class='sub-footer-currency'>
                {% render 'localization',
                    id: 'FooterLocalization',
                    show_language_switcher: show_language_switcher,
                    show_currency_switcher: show_currency_switcher,
                    open_top: true
                %}
            </div>
            <div class='sub-footer-copyright'>
                <p>
                    &copy; {{ 'now' | date: '%Y' }}
                    {{ shop.name }}, {{ copyright_text }}
                </p>
            </div>
            <div class='sub-footer-payment-icon-container'>
                {%- if show_payment_icons -%}
                    <div class='footer-payment-icons'>
                        {%- unless shop.enabled_payment_types == empty -%}
                            {%- for type in shop.enabled_payment_types -%}
                                <figure>{{ type | payment_type_svg_tag: class: 'payment-icons__icon' }}</figure>
                            {%- endfor -%}
                        {%- endunless -%}
                    </div>
                {%- endif -%}
            </div>
        </div>
    </div>
</theme-footer>
{% if footer_reveal_animation %}
    <script
        src='{{ 'footer.js' | asset_url }}'
        defer='defer'
    ></script>
{% endif %}
{% schema %}
{
    "name": "Footer",
    "settings": [
        {
            "type": "video",
            "id": "video",
            "label": "Background video"
        },
        {
            "type": "checkbox",
            "id": "footer_reveal_animation",
            "default": false,
            "label": "Enable reveal animation"
        },
        {
            "type": "text",
            "id": "copyright_text",
            "label": "Additional copyright text",
            "default": "All rights reserved."
        },
        {
            "type": "checkbox",
            "id": "show_language_switcher",
            "label": "Enable language switcher",
            "default": true,
            "info": "To add a language, go to your [language settings](/admin/settings/languages)."
        },
        {
            "type": "checkbox",
            "id": "show_currency_switcher",
            "label": "Enable currency switcher",
            "default": true,
            "info": "To add a country/region, go to your [payment settings](/admin/settings/payments)."
        },
        {
            "type": "checkbox",
            "id": "show_payment_icons",
            "label": "Show payment icons",
            "default": true,
            "info": "By default your theme shows the icons that are associated with the payment gateway you have enabled in the [payment settings](/admin/settings/payments)."
        }
    ],
    "blocks": [
        {
            "type": "@app"
        },
        {
            "type": "info",
            "name": "Info",
            "settings": [
                {
                    "type": "richtext",
                    "id": "info_title",
                    "label": "Info Title"
                },
                {
                    "type": "richtext",
                    "id": "info_description",
                    "label": "Info Description"
                },
                {
                    "type": "text",
                    "id": "info_button_text",
                    "label": "Info Button Text"
                }
            ]
        },
        {
            "type": "text",
            "name": "Text",
            "settings": [
                {
                    "type": "select",
                    "id": "column_size",
                    "label": "Column size",
                    "options": [
                        { "value": "small", "label": "Small" },
                        { "value": "medium", "label": "Medium" },
                        { "value": "large", "label": "Large" }
                    ],
                    "default": "small"
                },
                {
                    "type": "select",
                    "id": "text_alignment",
                    "options": [
                        {
                            "value": "left",
                            "label": "Left"
                        },
                        {
                            "value": "center",
                            "label": "Center"
                        },
                        {
                            "value": "right",
                            "label": "Right"
                        }
                    ],
                    "default": "left",
                    "label": "Text alignment"
                },
                {
                    "id": "title",
                    "type": "text",
                    "label": "Title"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Image",
                    "info": "240 x 100 px .png recommended."
                },
                {
                    "type": "richtext",
                    "id": "text",
                    "label": "Text",
                    "default": "<p>Add company info here.</p>"
                },
                {
                    "type": "select",
                    "id": "text_size",
                    "label": "Text size",
                    "options": [
                        {
                            "value": "small",
                            "label": "Small"
                        },
                        {
                            "value": "medium",
                            "label": "Medium"
                        },
                        {
                            "value": "large",
                            "label": "Large"
                        }
                    ],
                    "default": "medium"
                },
                {
                    "id": "button_text",
                    "type": "text",
                    "label": "Button label",
                    "default": "Explore",
                    "info": "Leave the label blank to hide the button."
                },
                {
                    "id": "button_link",
                    "type": "url",
                    "label": "Button link"
                },
                {
                    "type": "checkbox",
                    "id": "show_social_links",
                    "label": "Show social links",
                    "default": true
                }
            ]
        },
        {
            "type": "menu",
            "name": "Menu",
            "settings": [
                {
                    "type": "select",
                    "id": "column_size",
                    "label": "Column size",
                    "options": [
                        { "value": "small", "label": "Small" },
                        { "value": "medium", "label": "Medium" },
                        { "value": "large", "label": "Large" }
                    ],
                    "default": "small"
                },
                {
                    "id": "title",
                    "type": "text",
                    "label": "Title"
                },
                {
                    "type": "link_list",
                    "id": "menu",
                    "default": "footer",
                    "label": "Menu",
                    "info": "Select navigation to display"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "new-footer"
        }
    ]
}
{% endschema %}
