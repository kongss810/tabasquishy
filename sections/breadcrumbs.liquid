{{- 'breadcrumbs.css' | asset_url | stylesheet_tag -}}
<div class='container'>
    <scroll-shadow>
        <nav
            class='breadcrumbs'
            aria-label='breadcrumbs'
        >
            <a
                href='{{ routes.root_url }}'
                title='{{ 'sections.breadcrumbs.home' | t | escape }}'
            >
                {{ 'sections.breadcrumbs.home' | t }}
            </a>
            {% if collection.url %}
                <div>|</div>
                <a
                    href='{{ routes.all_products_collection_url }}'
                    title='{{ 'sections.breadcrumbs.shop' | t | escape }}'
                >
                    {{ 'sections.breadcrumbs.shop' | t }}
                </a>
                <div>|</div>
                {{ collection.title }}
            {% endif %}
            {% if template contains 'list-collections' %}
                <div>|</div>
                <a
                    href='{{ routes.all_products_collection_url }}'
                    title='{{ 'sections.breadcrumbs.shop' | t | escape }}'
                >
                    {{ 'sections.breadcrumbs.shop' | t }}
                </a>
                <div>|</div>
                {{ 'sections.breadcrumbs.collections' | t }}
            {% endif %}
            {% if template contains 'cart' %}
                <div>|</div>
                {{ 'sections.breadcrumbs.cart' | t }}
            {% endif %}
            {% if template contains 'product' %}
                <div>|</div>
                {{ product.title }}
            {% endif %}
            {% if template contains 'blog' %}
                {% if current_tags %}
                    <div>|</div>
                    <a
                        href='{{ blog.url }}'
                        title='{{ blog.title | escape }}'
                    >
                        {{ blog.title }}
                    </a>
                    <div>|</div>
                    {{ current_tags }}
                {% else %}
                    <div>|</div>
                    {{ blog.title }}
                {% endif %}
            {% endif %}
            {% if template contains 'article' %}
                <div>|</div>
                <a
                    href='{{ blog.url }}'
                    title='{{ blog.title | escape }}'
                >
                    {{ blog.title }}
                </a>
                <div>|</div>
                {{ article.title }}
            {% endif %}
            {% if template contains 'page' %}
                <div>|</div>
                {{ page.title }}
            {% endif %}
            {% if template contains 'search' %}
                <div>|</div>
                {{ 'sections.breadcrumbs.search' | t }}
            {% endif %}
            {% if template contains 'customers' %}
                <div>|</div>
                {{ 'sections.breadcrumbs.my_account' | t }}
            {% endif %}
        </nav>
    </scroll-shadow>
</div>
{% schema %}
{
    "name": "Breadcrumbs",
    "class": "breadcrumbs-section"
}
{% endschema %}
