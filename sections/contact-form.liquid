{%- render 'section-spacing', section: section -%}

<style>
    .contact-form .field-box textarea,
    .contact-form .field-box input {
        outline: none;
        box-shadow: unset;
    }
    .contact-form button:hover {
        color: #fff;
        background: #000;
    }

    .contact-form .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 32px 24px;
    }

    .contact-form .grid-columns {
        grid-column: span 2;
    }

    .contact-form .grid-columns-half {
        grid-column: span 1 !important;
    }

    .contact-form .field-box label {
        display: block;
        font-size: 18px;
        line-height: 120%;
        color: #1a1a1a;
        font-weight: 500;
        margin-bottom: 10px;
    }

    .contact-form .field-box label span {
        color: #e11919;
    }

    .contact-form .field-box input {
        border-radius: 999px;
        margin-bottom: 0;
        height: 48px;
        background: #fff;
    }

    .contact-form .field-box textarea {
        border-radius: 15px;
        margin-bottom: 0;
        background: #fff;
    }

    .contact-form .field-box textarea::placeholder {
        font-size: 14px;
        font-weight: 400;
        line-height: 110%;
        color: rgba(26, 26, 26, 0.4);
        opacity: 1;
    }

    .contact-form .footer-social .social-links {
        flex-wrap: wrap;
    }

    .contact-form .footer-social .social-links li {
        margin-bottom: 0;
        display: flex;
        width: 48px;
        height: 48px;
        padding: 3px 11px;
        justify-content: center;
        align-items: center;
        gap: 10px;
        aspect-ratio: 1 / 1;
        border-radius: 999px;
        background: #fcd454;
    }
    .contact-form .footer-social .social-links li a {
        display: flex;
    }
    .contact-form .footer-social .social-links svg {
        width: auto;
        height: auto;
    }

    @media only screen and (max-width: 767px) {
        .contact-form .form-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }
        .contact-form .footer-social .social-links {
            gap: 12px;
        }
        .contact-form .grid-columns,
        .contact-form .grid-columns-half {
            grid-column: span 1;
        }

        .contact-form .field-box label {
            font-size: 16px;
            line-height: 150%;
            font-weight: 500;
            margin-bottom: 4px;
        }

        .contact-form .field-box input {
            height: 40px;
            padding: 6px 12px;
            font-size: 14px;
        }

        .contact-form .field-box textarea {
            min-height: 142px;
            border-radius: 10px;
            padding: 6px 12px;
        }

        .contact-form .field-box textarea::placeholder,
        .contact-form .field-box input::placeholder {
            font-size: 12px;
            line-height: 150%;
            color: rgba(26, 26, 26, 0.4);
        }

        .contact-form .field.select select {
            height: 40px;
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 14px;
        }

        .contact-form .contact-form-item .img-box {
            width: 60px;
            height: 60px;
            flex-shrink: 0;
        }

        .contact-form .footer-social .social-links li {
            width: 40px;
            height: 40px;
            padding: 0;
        }

        .contact-form button[type='submit'] {
            height: 40px;
            margin-top: 0;
            margin-top: 8px;
        }

        .contact-form button[type='submit'] .single-add-to-cart-button--text,
        .contact-form button[type='submit'] span {
            font-size: 14px;
            line-height: 120%;
            font-weight: 500;
            text-transform: uppercase;
        }
    }
</style>

{%- liquid
    assign section_heading = section.settings.heading
    assign marker_style = section.settings.marker_style
    assign section_description = section.settings.description
    assign show_phone_number = section.settings.show_phone_number

    assign marker_color = section.settings.marker_color

    assign disable_top_spacing = section.settings.disable_top_spacing
    assign disable_bottom_spacing = section.settings.disable_bottom_spacing
    assign text_blocks = section.blocks | where: 'type', 'text'

    if section.blocks.size == 0
        assign form_class = 'contact-form--has-no-blocks'
    endif
-%}
{{- 'contact-form.css' | asset_url | stylesheet_tag -}}
<div class='contact-form container'>
    <div class='contact-form-header mb-0 flex flex-col items-start gap-[16px] text-left sm:mb-[80px] sm:items-center sm:gap-[20px] sm:text-center'>
        {% if section.settings.title != blank %}
            {%- if section.settings.highlighted_text == 'none' -%}
                <h2 class='header-title text-title hide_p w-full text-[32px] leading-[120%] font-[600] tracking-[-1.28] sm:text-[64px] sm:leading-[120%]'>
                    {{ section.settings.title }}
                </h2>
            {%- else -%}
                {%- render 'highlighted-text',
                    class: 'header-title text-title hide_p w-full text-[32px] font-[600] leading-[120%] tracking-[-1.28] sm:text-[64px] sm:leading-[120%]',
                    content: section.settings.title,
                    style: section.settings.highlighted_text,
                    scribble: 'sketch-underline',
                    gradient: with_gradient
                -%}
            {%- endif -%}
        {% endif %}

        {% if section.settings.description != blank %}
            <div class='contact-form-description hide_p text-text w-full text-[14px] leading-[150%] font-[400] sm:text-[24px] sm:leading-[100%]'>
                {{ section.settings.description }}
            </div>
        {% endif %}
    </div>

    <div class='contact-form-box mt-[52px] flex flex-col gap-[52px] sm:mt-0 sm:flex-row'>
        <div class='contact-form-left order-2 flex w-full flex-col gap-[52px] sm:order-1 sm:w-[50%] sm:max-w-[712px] sm:justify-between sm:gap-0 sm:px-[30px] sm:py-[60px]'>
            {%- if text_blocks.size > 0 -%}
                <div class='grid gap-[24px] sm:gap-[32px]'>
                    {% for block in section.blocks %}
                        {%- if block.type == 'text' -%}
                            <div class='contact-form-item flex items-center gap-[12px] sm:gap-[20px] sm:py-[12px]'>
                                {% if block.settings.image %}
                                    <div class='img-box h-[60px] w-[60px] shrink-0'>
                                        {% render 'section-img', img: block.settings.image, width: 200, loading: 'lazy' %}
                                    </div>
                                {% endif %}

                                <div
                                    class='contact-form-block min-w-0 flex-1'
                                    {{ block.shopify_attributes }}
                                >
                                    <div class='text-title text-[20px] leading-[120%] font-[600] tracking-[-0.28px] sm:text-[28px]'>
                                        {{ block.settings.heading }}
                                    </div>
                                    <div class='rte hide_p text-text mt-[8px] text-[14px] leading-[150%] font-[400] sm:mt-[12px] sm:text-[18px] sm:font-[500]'>
                                        {{ block.settings.text }}
                                    </div>
                                </div>
                            </div>
                        {%- endif -%}
                    {% endfor %}
                </div>
            {%- endif -%}

            {% if section.settings.show_social %}
                <div class='footer-social'>
                    <div class='widget widget--social flex items-center gap-[12px] sm:block'>
                        <div class='contact-form-share-label shrink-0 text-[18px] leading-[150%] font-[600] text-[#1a1a1a] sm:hidden'>Share:</div>
                        {% if section.settings.social_title != blank %}
                            <div class='thb-widget-title mb-[20px] hidden text-[28px] leading-[120%] font-[600] tracking-[-0.28px] sm:block'>
                                {{ section.settings.social_title }}
                            </div>
                        {% endif %}
                        {% render 'social-links', show_label: false %}
                    </div>
                </div>
            {% endif %}
        </div>
        <div class='contact-form--form-column order-1 w-full rounded-[10px] bg-[#FCD454] px-[12px] py-[32px] sm:order-2 sm:w-[50%] sm:max-w-[750px] sm:rounded-[15px] sm:p-[48px]'>
            <div class='fomr-title text-title mb-[48px] hidden text-[32px] leading-[100%] font-[600] sm:block'>{{ section.settings.form_title }}</div>
            {% form 'contact', class: form_class %}
                {% if form.posted_successfully? %}
                    <div class='form-notification success'>
                        {% render 'svg-icons' with 'thb-success' %}
                        {{ 'sections.contact.form.post_success' | t }}
                    </div>
                {%- elsif form.errors %}
                    <div class='form-notification error'>
                        {% render 'svg-icons' with 'thb-error' %}
                        {{ 'sections.contact.form.error_heading' | t }}
                        {{ form.errors | default_errors }}
                    </div>
                {% endif %}
                <div class='form-grid'>
                    <div class='grid-columns grid-columns-half'>
                        <div class='field-box'>
                            <label for='ContactFormName'>
                                {{ 'sections.contact.form.name' | t }}
                                <span>*</span>
                            </label>
                            <input
                                type='text'
                                id='ContactFormName'
                                name='contact[name]'
                                class='full'
                                required
                            >
                        </div>
                    </div>
                    <div class='grid-columns grid-columns-half'>
                        <div class='field-box'>
                            <label for='ContactFormEmail'>
                                {{ 'sections.contact.form.email' | t }}
                                <span>*</span>
                            </label>
                            <input
                                type='email'
                                id='ContactFormEmail'
                                name='contact[email]'
                                class='full'
                                pattern='^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$'
                                required
                            >
                        </div>
                    </div>
                    {%- if show_phone_number -%}
                        <div class='grid-columns'>
                            <div class='field-box'>
                                <label for='ContactFormPhone'>{{ 'sections.contact.form.phone' | t }}</label>
                                <input
                                    type='tel'
                                    id='ContactFormPhone'
                                    name='contact[phone]'
                                    class='full'
                                    placeholder='{{ 'sections.contact.form.phone' | t | escape }}'
                                >
                            </div>
                        </div>
                    {%- endif -%}
                    {%- for block in section.blocks -%}
                        {%- liquid
                            assign field_title = block.settings.title
                            if field_title == blank
                                capture field_title
                                    echo 'Custom field ' | append: field_index
                                endcapture
                            endif
                        -%}
                        {%- case block.type -%}
                            {%- when 'text_field' -%}
                                <div class='grid-columns'>
                                    <div class='field-box'>
                                        {%- if block.settings.use_long_text -%}
                                            <label for='{{ block.id }}'>{{ block.settings.title | escape }}</label>
                                            <textarea
                                                id='{{ block.id }}'
                                                name='contact[{{ field_title | escape }}]'
                                                cols='30'
                                                rows='10'
                                                class='full'
                                                aria-label='{{ block.settings.title | escape }}'
                                                {% if block.settings.is_required %}
                                                    required
                                                {% endif -%}
                                            ></textarea>
                                        {%- else -%}
                                            <label for='{{ block.id }}'>{{ block.settings.title | escape }}</label>
                                            <input
                                                id='{{ block.id }}'
                                                type='text'
                                                class='full'
                                                name='contact[{{ field_title | escape }}]'
                                                aria-label='{{ block.settings.title | escape }}'
                                                {% if block.settings.is_required %}
                                                    required
                                                {% endif %}
                                            >
                                        {%- endif -%}
                                    </div>
                                </div>
                                {%- assign field_index = field_index | plus: 1 -%}
                            {%- when 'dropdown_field' -%}
                                {%- liquid
                                    assign values = block.settings.values | split: ','
                                    if values == empty
                                        continue
                                    endif
                                -%}
                                <div class='grid-columns'>
                                    <div class='field select'>
                                        <label for='{{ block.id }}'>{{ block.settings.title | escape }}</label>
                                        <select
                                            class='full'
                                            name='contact[{{ field_title | escape }}]'
                                            title='{{ block.settings.title | escape }}'
                                            required
                                        >
                                            <option
                                                value=''
                                                disabled
                                                selected
                                            >
                                                {{ block.settings.title | escape }}
                                            </option>
                                            {%- for value in values -%}
                                                {%- assign trim_value = value | strip -%}
                                                <option value='{{ trim_value | escape }}'>{{ trim_value | escape }}</option>
                                            {%- endfor -%}
                                        </select>
                                    </div>
                                </div>
                                {%- assign field_index = field_index | plus: 1 -%}
                        {%- endcase -%}
                    {%- endfor -%}
                    <div class='grid-columns'>
                        <div class='field-box'>
                            <label for='ContactFormMessage'>{{ 'sections.contact.form.comment' | t }}</label>
                            <textarea
                                rows='10'
                                id='ContactFormMessage'
                                name='contact[body]'
                                class='full'
                                placeholder='{{ 'sections.contact.form.placeholder_message' | t | escape }}'
                            ></textarea>
                        </div>
                    </div>
                    <div class='grid-columns'>
                        <button
                            type='submit'
                            class='button full h-[40px] rounded-[999px] bg-[#000] text-[#fff] sm:mt-[16px] sm:h-[56px]'
                        >
                            <span class='text-[14px] leading-[120%] font-[500] uppercase sm:text-[16px] sm:leading-[150%] sm:font-[400] sm:normal-case'>
                                {{ 'sections.contact.form.send' | t }}
                            </span>
                        </button>
                    </div>
                </div>
            {% endform %}
        </div>
    </div>
</div>

{% schema %}
{
    "name": "Contact form",
    "class": "css-layout",
    "settings": [
        {
            "type": "richtext",
            "id": "title",
            "label": "title"
        },
        {
            "type": "richtext",
            "id": "description",
            "label": "Description",
            "default": "<p>Add a short description for this section</p>"
        },
        {
            "type": "text",
            "id": "form_title",
            "label": "Form title"
        },
        {
            "type": "text",
            "id": "social_title",
            "label": "Social title"
        },
        {
            "type": "checkbox",
            "id": "show_social",
            "default": true,
            "label": "Show Social"
        },
        {
            "type": "checkbox",
            "id": "show_phone_number",
            "default": true,
            "label": "Show phone number"
        },
        {
            "type": "header",
            "content": "Highlighted text",
            "info": "To add an animated highlight to text, simply wrap it in italics. Click the I button in the editor to toggle italics when highlighting text."
        },
        {
            "type": "select",
            "id": "highlighted_text",
            "options": [
                {
                    "value": "none",
                    "label": "None"
                },
                {
                    "value": "scribble",
                    "label": "Hand-drawn scribble"
                }
            ],
            "default": "none",
            "label": "Highlighted text"
        },
        {
            "type": "header",
            "content": "Spacing Top:"
        },
        {
            "type": "number",
            "id": "Desktop_paddingTop",
            "label": "Desktop Padding Top",
            "default": 0
        },
        {
            "type": "number",
            "id": "Mobile_paddingTop",
            "label": "Mobile Padding Top",
            "default": 0
        },
        {
            "type": "header",
            "content": "Spacing Bottom:"
        },
        {
            "type": "number",
            "id": "Desktop_paddingBottom",
            "label": "Desktop Padding Bottom",
            "default": 0
        },
        {
            "type": "number",
            "id": "Mobile_paddingBottom",
            "label": "Mobile Padding Bottom",
            "default": 0
        }
    ],
    "blocks": [
        {
            "type": "text",
            "name": "Text",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Icon Image"
                },
                {
                    "type": "text",
                    "id": "heading",
                    "label": "Heading",
                    "default": "Heading"
                },
                {
                    "type": "richtext",
                    "id": "text",
                    "label": "Content",
                    "default": "<p>Add your store address or<br\/>your store hours</p>"
                }
            ]
        },
        {
            "type": "text_field",
            "name": "Text field",
            "settings": [
                {
                    "type": "text",
                    "id": "title",
                    "label": "Name",
                    "default": "Custom field"
                },
                {
                    "type": "checkbox",
                    "id": "use_long_text",
                    "label": "Use long text",
                    "default": false
                },
                {
                    "type": "checkbox",
                    "id": "is_required",
                    "label": "Field is required",
                    "default": false
                }
            ]
        },
        {
            "type": "dropdown_field",
            "name": "Dropdown field",
            "settings": [
                {
                    "type": "text",
                    "id": "title",
                    "label": "Name",
                    "default": "Custom field"
                },
                {
                    "type": "text",
                    "id": "values",
                    "label": "Values",
                    "info": "Separate each value by a comma.",
                    "default": "value 1, value 2, value 3"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Contact form",
            "blocks": [
                {
                    "type": "text"
                },
                {
                    "type": "text"
                }
            ]
        }
    ]
}
{% endschema %}
