{%- render 'section-spacing', section: section -%}

<style>
    .index_collection_items {
        display: none;
    }
    .index_collection_items.active {
        display: block;
    }
    .indexCollection_topBox.active {
        background: #f3f3f3;
        font-weight: 600;
        border-color: #f3f3f3;
    }
    .indexCollection_topBox:hover {
        background: #f3f3f3;
        border-color: #f3f3f3;
    }
    @media (min-width: 1024px) {
    }
    @media (max-width: 1023px) {
    }
</style>
<div class='index-collection-all'>
    <div class='container'>
        <div class='indexCollection_top mb-[52px] flex items-end justify-between gap-[40px] sm:mb-[38px]'>
            <div class='indexCollection_topLeft max-w-[55%]'>
                {% if section.settings.title != blank %}
                    {%- if section.settings.highlighted_text == 'none' -%}
                        <h2 class='header-title text-title hide_p text-[28px] leading-[113%] font-[600] tracking-[0] sm:text-[64px] sm:leading-[120%]'>
                            {{ section.settings.title }}
                        </h2>
                    {% else %}
                        {%- render 'highlighted-text',
                            class: 'header-title text-title hide_p text-[28px] sm:text-[64px] font-[600] sm:leading-[120%] leading-[113%] tracking-[0]',
                            content: section.settings.title,
                            style: section.settings.highlighted_text,
                            scribble: 'sketch-underline',
                            gradient: with_gradient
                        -%}
                    {% endif %}
                {% endif %}

                {% if section.settings.text != blank %}
                    <div
                        class='indexCollection_topText mt-[20px] text-left text-[16px]'
                        style='color: {{section.settings.text_color}};'
                    >
                        {{ section.settings.text }}
                    </div>
                {% endif %}
            </div>
            {% if section.blocks.size > 1 %}
                <div class='indexCollection_topRight  flex max-w-[45%] flex-wrap gap-[24px]'>
                    {% for block in section.blocks %}
                        <div class='indexCollection_topBox text-[#1a1a1a] transition-all duration-300 {% if forloop.first %}active{% endif %} flex h-[44px] cursor-pointer items-center justify-center rounded-[50px] border-1 border-[rgba(26,26,26,0.20)] px-[20px]'>
                            {{ block.settings.tab }}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
        <div class='index_collection_box'>
            <div class='index_collection_boxList'>
                {% for block in section.blocks %}
                    <div
                        class='
                            index_collection_items
                            block-{{ block.id }} {% if forloop.first %}
                                active
                            {% endif %}
                        '
                    >
                        <div class='swiper_2 swiper indexCollectionSwiper'>
                            <div class='swiper-wrapper'>
                                {% for product in block.settings.collection.products limit: section.settings.product_limit %}
                                    <div class='swiper-slide'>
                                        {%- render 'product-card-new', product_card_product: product -%}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            {% if section.blocks.size > 0 %}
                <div class='indexCollection_buttons swiper-buttons mt-[52px] flex items-center justify-between gap-[20px]'>
                    <div class='swiper_buttons_left'>
                        <div class='swiper-pagination'></div>
                    </div>
                    <div class='swiper_buttons_right'>
                        <div class='swiper-button-prev'>
                            <svg
                                xmlns='http://www.w3.org/2000/svg'
                                width='11'
                                height='23'
                                viewBox='0 0 11 23'
                                fill='none'
                            >
                                <path d="M9.67364 2.32616L0.999802 11L9.67364 19.6738" stroke="#161A1F" stroke-opacity="0.6" stroke-width="1.15" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class='swiper-button-next'>
                            <svg
                                xmlns='http://www.w3.org/2000/svg'
                                width='11'
                                height='23'
                                viewBox='0 0 11 23'
                                fill='none'
                            >
                                <path d="M1.05973 2.32616L9.73358 11L1.05973 19.6738" stroke="#161A1F" stroke-opacity="0.6" stroke-width="1.15" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const topBoxes = document.querySelectorAll('#shopify-section-{{section.id}} .indexCollection_topBox');
        const items = document.querySelectorAll('#shopify-section-{{section.id}} .index_collection_items');
        const tabsContainer = document.querySelector('#shopify-section-{{section.id}} .indexCollection_topRight');
        let currentSwiper = null;

        const swiperOptions = {
            observer: true,
            observeParents: true,
            watchOverflow: true,
            mousewheel: {
                forceToAxis: true,
            },
            breakpoints: {
                300: {
                    slidesPerView: 1.1,
                    spaceBetween: 15,
                },
                740: {
                    slidesPerView: 2,
                    spaceBetween: 20,
                },
                1200: {
                    slidesPerView: 4,
                    spaceBetween: 24,
                },
            },
            navigation: {
                nextEl: '#shopify-section-{{section.id}} .swiper-button-next',
                prevEl: '#shopify-section-{{section.id}} .swiper-button-prev',
            },
            pagination: {
                el: '#shopify-section-{{section.id}} .swiper-pagination',
                type: 'progressbar',
            },
        };

        function initSwiperOn(container) {
            const swiperEl = container.querySelector('.indexCollectionSwiper');
            if (!swiperEl) return;

            const buttons = document.querySelector('#shopify-section-{{section.id}} .swiper-buttons');
            const slideCount = swiperEl.querySelectorAll('.swiper-slide').length;

            // 根据当前集合的 slide 数量决定是否显示按钮并调整 margin-top
            if (buttons) {
                if (slideCount > 4) {
                    buttons.style.display = '';
                    buttons.style.marginTop = '';
                } else {
                    buttons.style.display = 'none';
                    buttons.style.marginTop = '0px';
                }
            }

            currentSwiper = new Swiper(swiperEl, swiperOptions);
        }

        // If tabs are 0 or 1, hide the tabs container (liquid already hides when <=1, this is a JS fallback)
        if (!topBoxes || topBoxes.length <= 1) {
            if (tabsContainer) tabsContainer.style.display = 'none';
        }

        // Initialize the first (active) swiper
        const activeItem = document.querySelector('#shopify-section-{{section.id}} .index_collection_items.active');
        if (activeItem) initSwiperOn(activeItem);

        // Click handling for tab boxes
        topBoxes.forEach((box, idx) => {
            box.addEventListener('click', function () {
                if (box.classList.contains('active')) return;
                topBoxes.forEach((b) => b.classList.remove('active'));
                box.classList.add('active');
                items.forEach((it) => it.classList.remove('active'));
                const target = items[idx];
                if (target) {
                    target.classList.add('active');
                    // destroy previous swiper before creating new one
                    if (currentSwiper && typeof currentSwiper.destroy === 'function') {
                        try {
                            currentSwiper.destroy(true, true);
                        } catch (e) {
                            /* ignore */
                        }
                        currentSwiper = null;
                    }
                    initSwiperOn(target);
                }
            });
        });
    });
</script>

{% schema %}
{
    "name": "Index Collection",
    "class": "css-layout",
    "settings": [
        {
            "type": "richtext",
            "id": "title",
            "label": "title"
        },
        {
            "type": "header",
            "content": "Highlighted text",
            "info": "To add an animated highlight to text, simply wrap it in italics. Click the I button in the editor to toggle italics when highlighting text."
        },
        {
            "type": "select",
            "id": "highlighted_text",
            "options": [
                {
                    "value": "none",
                    "label": "None"
                },
                {
                    "value": "scribble",
                    "label": "Hand-drawn scribble"
                }
            ],
            "default": "none",
            "label": "Highlighted text"
        },
        {
            "type": "inline_richtext",
            "id": "text",
            "label": "text"
        },
        {
            "type": "color",
            "id": "text_color",
            "label": "text color",
            "default": "#333333"
        },
        {
            "type": "range",
            "id": "product_limit",
            "min": 1,
            "max": 20,
            "step": 1,
            "label": "Product Limit",
            "default": 10
        },
        {
            "type": "header",
            "content": "Spacing Top:"
        },

        {
            "type": "number",
            "id": "Desktop_paddingTop",
            "label": "Desktop Padding Top",
            "default": 0
        },
        {
            "type": "number",
            "id": "Mobile_paddingTop",
            "label": "Mobile Padding Top",
            "default": 0
        },

        {
            "type": "header",
            "content": "Spacing Bottom:"
        },
        {
            "type": "number",
            "id": "Desktop_paddingBottom",
            "label": "Desktop Padding Bottom",
            "default": 0
        },
        {
            "type": "number",
            "id": "Mobile_paddingBottom",
            "label": "Mobile Padding Bottom",
            "default": 0
        }
    ],
    "blocks": [
        {
            "type": "item",
            "name": "Item",
            "settings": [
                {
                    "type": "text",
                    "id": "tab",
                    "label": "tab"
                },
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "collection"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Index Collection"
        }
    ]
}
{% endschema %}
