{%- render 'section-spacing', section: section -%}
<link
    rel='stylesheet'
    href='{{ 'swiper.css' | asset_url }}'
>
<script src='{{ 'swiper.js' | asset_url }}'></script>

<style>
    #shopify-section-{{ section.id }} {
        background: {{ section.settings.background_color }};
        {% if section.settings.background_image != blank %}
            background-image: url({{ section.settings.background_image | image_url: width: 2400 }});
            background-repeat: no-repeat;
            background-position: right;
            background-size: 100% 100%;
        {% endif %}
    }
    {% if section.settings.show_all_product_cards %}
    .index-positive-all--show-all-products {}
    {% endif %}
    @media (min-width: 1024px) {
        .index-positive-all .header-title strong {
            font-weight: 600 !important;
            background: linear-gradient(90deg, #ed8e25 0%, #e40078 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            color: transparent;
        }

        .index-media-item .index-media-box img,
        .index-media-item .index-media-box video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .indexpositiveSwiper .swiper-slide {
            transform: scale(0.86);
            transition: transform 300ms;
        }

        .indexpositiveSwiper .swiper-slide-active {
            transform: scale(1);
        }

        .index-media-item .product-box {
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.5s ease;
        }
        .indexpositiveSwiper .swiper-slide-active .product-box,
        .index-positive-all--show-all-products .index-media-item .product-box {
            opacity: 1;
            pointer-events: unset;
        }
        .product-left-info:hover {
            color: inherit !important;
        }
    }
</style>

<div class='index-positive-all{% if section.settings.show_all_product_cards %} index-positive-all--show-all-products{% endif %}'>
    <div class='container'>
        {%- if section.settings.title != blank -%}
            {%- if section.settings.highlighted_text == 'none' -%}
                <h2 class='header-title text-title hide_p text-center text-[28px] leading-[113%] font-[600] tracking-[0] sm:text-[64px] sm:leading-[120%]'>
                    {{ section.settings.title }}
                </h2>
            {% else %}
                {%- render 'highlighted-text',
                    class: 'header-title text-title text-center hide_p text-[28px] sm:text-[64px] font-[600] sm:leading-[120%] leading-[113%] tracking-[0]',
                    content: section.settings.title,
                    style: section.settings.highlighted_text,
                    scribble: 'sketch-underline',
                    gradient: with_gradient
                -%}
            {% endif %}
        {%- endif -%}
        {% if section.settings.number_reviews != blank %}
            <div class='number-reviews-box mt-[20px] flex items-start justify-center gap-[4px]'>
                {% render 'section-img', img: section.settings.star_img, width: 200, mobile_width: 200, class: 'w-[116px] leading-[100%]' %}
                <div class='number-reviews text-text text-[28px] leading-[113%] font-[600] tracking-[0] sm:text-[16px] sm:leading-[150%]'>
                    {{ section.settings.number_reviews }}
                </div>
            </div>
        {% endif %}

        <div class='index-positive-content mt-[57px]'>
            <div class='swiper_1 swiper indexpositiveSwiper px-[50px] indexpositiveSwiper-{{ section.id }}'>
                <div class='swiper-wrapper'>
                    {%- for block in section.blocks -%}
                        <div class='swiper-slide index-media-item'>
                            <div class='index-media-box h-[100%] overflow-hidden rounded-[15px]'>
                                {% if block.settings.video != blank %}
                                    {{
                                        block.settings.video
                                        | video_tag: autoplay: false, playsinline: true, loop: true, controls: false, muted: true, image_size: '1000x'
                                    }}
                                {%- else -%}
                                    {% render 'section-img', img: block.settings.pc_image, img_mobile: block.settings.pc_image %}
                                {% endif %}
                            </div>
                            {% if block.settings.product != blank %}
                                <product-card
                                    class='product-box mt-[16px] flex h-[104px] items-center justify-between gap-[12px] overflow-hidden rounded-[15px] border border-[rgba(26,26,26,0.2)] bg-cover bg-center bg-no-repeat p-[12px]'
                                    style='background: {{ section.settings.product_box_background_color }};{% if section.settings.product_box_background_image != blank %} background-image: url({{ section.settings.product_box_background_image | image_url: width: 1200 }});{% endif %}'
                                >
                                    <a
                                        class='product-left-info flex items-center gap-[12px]'
                                        href='{{ block.settings.product.url }}'
                                    >
                                        <div class='product-img-box h-[80px] w-[80px] flex-shrink-0'>
                                            <img
                                                class='img h-full w-full object-contain'
                                                loading='lazy'
                                                width='auto'
                                                height='auto'
                                                src='{{ block.settings.product.featured_media | image_url }}'
                                            >
                                        </div>
                                        <div class='product-info-box'>
                                            <div class='title line-clamp-2 text-[16px] leading-[113%] font-[400] tracking-[-1%] sm:leading-[120%]'>
                                                {{ block.settings.product.title }}
                                            </div>
                                            <span class='price mt-[12px] text-[16px] leading-[113%] font-[600] tracking-[-4%] sm:leading-[100%]'>
                                                {% if block.settings.product.selected_or_first_available_variant.price != blank %}
                                                    {{ block.settings.product.selected_or_first_available_variant.price | money }}
                                                {%- else -%}
                                                    {{ block.settings.product.price | money }}
                                                {% endif %}
                                            </span>
                                        </div>
                                    </a>
                                    {% if block.settings.product.selected_or_first_available_variant.available %}
                                        <button
                                            class='add-cart-btn product-card--add-to-cart-button product-card--add-to-cart-button-simple relative mt-[0px] flex h-[48px] w-[48px] flex-shrink-0 cursor-pointer overflow-hidden rounded-[50%] bg-[#FCD454]'
                                            data-product-id='{{ block.settings.product.selected_or_first_available_variant.id }}'
                                        >
                                            {% render 'svg-icons' with 'thb-loading' %}
                                            <svg
                                                class='cart-icon'
                                                width='48'
                                                height='48'
                                                viewBox='0 0 48 48'
                                                fill='none'
                                                xmlns='http://www.w3.org/2000/svg'
                                            >
                                                <rect width="48" height="48" rx="24" fill="#FCD454"/>
                                                <mask id="mask0_680_3975" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="12" y="12" width="24" height="24">
                                                <rect x="12" y="12" width="24" height="24" fill="#D9D9D9"/>
                                                </mask>
                                                <g mask="url(#mask0_680_3975)">
                                                <path d="M15.9029 34.5C15.3711 34.5 14.9211 34.3158 14.5526 33.9474C14.1842 33.5789 14 33.1289 14 32.5971V20.6134C14 20.0817 14.1842 19.6316 14.5526 19.2632C14.9211 18.8947 15.3711 18.7105 15.9029 18.7105H20.0526V16.4474C20.0526 15.357 20.4379 14.4265 21.2084 13.6558C21.9791 12.8853 22.9096 12.5 24 12.5C25.0904 12.5 26.0209 12.8853 26.7916 13.6558C27.5621 14.4265 27.9474 15.357 27.9474 16.4474V18.7105H32.0971C32.6289 18.7105 33.0789 18.8947 33.4474 19.2632C33.8158 19.6316 34 20.0817 34 20.6134V32.5971C34 33.1289 33.8158 33.5789 33.4474 33.9474C33.0789 34.3158 32.6289 34.5 32.0971 34.5H15.9029ZM15.9029 32.9211H32.0971C32.1782 32.9211 32.2524 32.8873 32.3197 32.8197C32.3873 32.7524 32.4211 32.6782 32.4211 32.5971V20.6134C32.4211 20.5324 32.3873 20.4582 32.3197 20.3908C32.2524 20.3232 32.1782 20.2895 32.0971 20.2895H27.9474V22.6579C27.9474 22.8819 27.8718 23.0695 27.7205 23.2205C27.5695 23.3718 27.3819 23.4474 27.1579 23.4474C26.9339 23.4474 26.7463 23.3718 26.5953 23.2205C26.444 23.0695 26.3684 22.8819 26.3684 22.6579V20.2895H21.6316V22.6579C21.6316 22.8819 21.556 23.0695 21.4047 23.2205C21.2537 23.3718 21.0661 23.4474 20.8421 23.4474C20.6181 23.4474 20.4305 23.3718 20.2795 23.2205C20.1282 23.0695 20.0526 22.8819 20.0526 22.6579V20.2895H15.9029C15.8218 20.2895 15.7476 20.3232 15.6803 20.3908C15.6127 20.4582 15.5789 20.5324 15.5789 20.6134V32.5971C15.5789 32.6782 15.6127 32.7524 15.6803 32.8197C15.7476 32.8873 15.8218 32.9211 15.9029 32.9211ZM21.6316 18.7105H26.3684V16.4474C26.3684 15.7875 26.1387 15.2278 25.6792 14.7682C25.2197 14.3087 24.66 14.0789 24 14.0789C23.34 14.0789 22.7803 14.3087 22.3208 14.7682C21.8613 15.2278 21.6316 15.7875 21.6316 16.4474V18.7105Z" fill="#1A1A1A"/>
                                                </g>
                                            </svg>
                                            <span class='product-card--add-to-cart-text'></span>
                                        </button>
                                    {% else %}
                                        <button
                                            class='sold_out_btn cursor-not-allowed opacity-50'
                                            disabled
                                            data-id='{{ block.settings.product.selected_or_first_available_variant.id }}'
                                        >
                                            <svg
                                                width='48'
                                                height='48'
                                                viewBox='0 0 48 48'
                                                fill='none'
                                                xmlns='http://www.w3.org/2000/svg'
                                            >
                                                <rect width="48" height="48" rx="24" fill="#FCD454"/>
                                                <mask id="mask0_680_3975" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="12" y="12" width="24" height="24">
                                                <rect x="12" y="12" width="24" height="24" fill="#D9D9D9"/>
                                                </mask>
                                                <g mask="url(#mask0_680_3975)">
                                                <path d="M15.9029 34.5C15.3711 34.5 14.9211 34.3158 14.5526 33.9474C14.1842 33.5789 14 33.1289 14 32.5971V20.6134C14 20.0817 14.1842 19.6316 14.5526 19.2632C14.9211 18.8947 15.3711 18.7105 15.9029 18.7105H20.0526V16.4474C20.0526 15.357 20.4379 14.4265 21.2084 13.6558C21.9791 12.8853 22.9096 12.5 24 12.5C25.0904 12.5 26.0209 12.8853 26.7916 13.6558C27.5621 14.4265 27.9474 15.357 27.9474 16.4474V18.7105H32.0971C32.6289 18.7105 33.0789 18.8947 33.4474 19.2632C33.8158 19.6316 34 20.0817 34 20.6134V32.5971C34 33.1289 33.8158 33.5789 33.4474 33.9474C33.0789 34.3158 32.6289 34.5 32.0971 34.5H15.9029ZM15.9029 32.9211H32.0971C32.1782 32.9211 32.2524 32.8873 32.3197 32.8197C32.3873 32.7524 32.4211 32.6782 32.4211 32.5971V20.6134C32.4211 20.5324 32.3873 20.4582 32.3197 20.3908C32.2524 20.3232 32.1782 20.2895 32.0971 20.2895H27.9474V22.6579C27.9474 22.8819 27.8718 23.0695 27.7205 23.2205C27.5695 23.3718 27.3819 23.4474 27.1579 23.4474C26.9339 23.4474 26.7463 23.3718 26.5953 23.2205C26.444 23.0695 26.3684 22.8819 26.3684 22.6579V20.2895H21.6316V22.6579C21.6316 22.8819 21.556 23.0695 21.4047 23.2205C21.2537 23.3718 21.0661 23.4474 20.8421 23.4474C20.6181 23.4474 20.4305 23.3718 20.2795 23.2205C20.1282 23.0695 20.0526 22.8819 20.0526 22.6579V20.2895H15.9029C15.8218 20.2895 15.7476 20.3232 15.6803 20.3908C15.6127 20.4582 15.5789 20.5324 15.5789 20.6134V32.5971C15.5789 32.6782 15.6127 32.7524 15.6803 32.8197C15.7476 32.8873 15.8218 32.9211 15.9029 32.9211ZM21.6316 18.7105H26.3684V16.4474C26.3684 15.7875 26.1387 15.2278 25.6792 14.7682C25.2197 14.3087 24.66 14.0789 24 14.0789C23.34 14.0789 22.7803 14.3087 22.3208 14.7682C21.8613 15.2278 21.6316 15.7875 21.6316 16.4474V18.7105Z" fill="#1A1A1A"/>
                                                </g>
                                            </svg>
                                        </button>
                                    {% endif %}
                                </product-card>
                            {% endif %}
                        </div>
                    {%- endfor -%}
                </div>
                <div class='my-swiper-button swiper-button-prev left-0 mt-[-76px]'>
                    {%- render 'icon' with 'swiper-prev' -%}
                </div>
                <div class='my-swiper-button swiper-button-next right-0 mt-[-76px]'>
                    {%- render 'icon' with 'swiper-next' -%}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var indexpositiveSwiper = new Swiper('.indexpositiveSwiper-{{ section.id }}', {
        observer: true,
        observeParents: true,
        loop: true,
        centeredSlides: true,
        autoplay: {% if section.settings.enable_autoplay %}{ delay: {{ section.settings.autoplay_delay | times: 1000 }}, disableOnInteraction: false }{% else %}false{% endif %},
        breakpoints: {
            320: {
                //当屏幕宽度大于等于320
                slidesPerView: 1.8,
                spaceBetween: 16,
            },
            768: {
                slidesPerView: 3,
                spaceBetween: 25,
            },
            1000: {
                slidesPerView: 3,
                spaceBetween: 50,
            },
            1200: {
                slidesPerView: 3,
                spaceBetween: 100,
            },
            1400: {
                slidesPerView: 3,
                spaceBetween: 150,
            },
        },
        on: {
            init: function () {
                handleVideoPlayback(this);
            },
            slideChangeTransitionEnd: function () {
                handleVideoPlayback(this);
            },
        },
        navigation: {
            nextEl: '.indexpositiveSwiper-{{ section.id }} .swiper-button-next',
            prevEl: '.indexpositiveSwiper-{{ section.id }} .swiper-button-prev',
        },
    });

    function handleVideoPlayback(swiper) {
        Array.from(swiper.slides).forEach((slide) => {
            const video = slide.querySelector('video');
            if (!video) {
                return;
            }

            const slideIndex = Number(slide.getAttribute('data-swiper-slide-index'));
            if (slideIndex === swiper.realIndex) {
                video.play().catch(() => {});
                return;
            }

            video.pause();
            video.currentTime = 0;
        });
    }
    (function () {
        function parseNumber(str) {
            const clean = str.trim();
            const match = clean.match(/^([\d,]+)(.*)?$/);
            if (!match) return null;

            const value = parseInt(match[1].replace(/,/g, ''), 10);
            const suffix = match[2] || '';
            return { value, suffix, original: clean };
        }
        function getDuration(value) {
            if (value >= 1000000) return 3000;
            if (value >= 10000) return 2000;
            if (value >= 1000) return 1500;
            if (value >= 100) return 1200;
            return 800;
        }
        function formatNumber(num, originalStr) {
            if (originalStr.includes(',')) {
                return num.toLocaleString('en-US');
            }
            return num.toString();
        }

        function animateCounter(el) {
            const parsed = parseNumber(el.textContent);
            if (!parsed) return;

            const { value, suffix, original } = parsed;
            const duration = getDuration(value);
            const startTime = performance.now();

            function update(currentTime) {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 4);
                const current = Math.floor(eased * value);

                el.textContent = formatNumber(current, original) + suffix;

                if (progress < 1) {
                    requestAnimationFrame(update);
                } else {
                    el.textContent = original;
                }
            }

            requestAnimationFrame(update);
        }

        function init() {
            const section = document.querySelector('.index-positive-all');
            if (!section) return;

            // 查找 header-title 中的所有 <strong> 标签
            const headerTitle = section.querySelector('.header-title');
            if (!headerTitle) return;

            const strongElements = headerTitle.querySelectorAll('strong');
            if (!strongElements.length) return;

            let animated = false;

            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting && !animated) {
                            animated = true;
                            strongElements.forEach((el) => animateCounter(el));
                            observer.disconnect();
                        }
                    });
                },
                {
                    threshold: 0.3,
                },
            );

            observer.observe(section);
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    })();
</script>

{% schema %}
{
    "name": "index-positive-reviews",
    "class": "css-layout",
    "settings": [
        {
            "type": "richtext",
            "id": "title",
            "label": "Title"
        },
        {
            "type": "header",
            "content": "Highlighted text",
            "info": "To add an animated highlight to text, simply wrap it in italics. Click the I button in the editor to toggle italics when highlighting text."
        },
        {
            "type": "select",
            "id": "highlighted_text",
            "options": [
                {
                    "value": "none",
                    "label": "None"
                },
                {
                    "value": "scribble",
                    "label": "Hand-drawn scribble"
                }
            ],
            "default": "none",
            "label": "Highlighted text"
        },
        {
            "type": "image_picker",
            "id": "star_img",
            "label": "Star Image"
        },
        {
            "type": "text",
            "id": "number_reviews",
            "label": "Number of reviews"
        },
        {
            "type": "checkbox",
            "id": "show_all_product_cards",
            "label": "Show all product cards",
            "default": false,
            "info": "When disabled, only the highlighted slide shows its product card."
        },
        {
            "type": "checkbox",
            "id": "enable_autoplay",
            "label": "Enable autoplay",
            "default": false
        },
        {
            "type": "range",
            "id": "autoplay_delay",
            "label": "Autoplay delay",
            "min": 2,
            "max": 12,
            "step": 1,
            "unit": "s",
            "default": 5
        },
        {
            "type": "color_background",
            "id": "background_color",
            "label": "Background color",
            "default": "transparent"
        },
        {
            "type": "image_picker",
            "id": "background_image",
            "label": "Background image"
        },
        {
            "type": "color",
            "id": "product_box_background_color",
            "label": "Product box background color"
        },
        {
            "type": "image_picker",
            "id": "product_box_background_image",
            "label": "Product box background image"
        },

        {
            "type": "header",
            "content": "Spacing Top:"
        },
        {
            "type": "number",
            "id": "Desktop_top",
            "label": "Desktop Margin Top",
            "default": 0
        },
        {
            "type": "number",
            "id": "Desktop_paddingTop",
            "label": "Desktop Padding Top",
            "default": 0
        },
        {
            "type": "number",
            "id": "Mobile_top",
            "label": "Mobile Margin Top",
            "default": 0
        },
        {
            "type": "number",
            "id": "Mobile_paddingTop",
            "label": "Mobile Padding Top",
            "default": 0
        },
        {
            "type": "header",
            "content": "Spacing Bottom:"
        },
        {
            "type": "number",
            "id": "Desktop_bottom",
            "label": "Desktop Margin Bottom",
            "default": 0
        },
        {
            "type": "number",
            "id": "Desktop_paddingBottom",
            "label": "Desktop Padding Bottom",
            "default": 0
        },
        {
            "type": "number",
            "id": "Mobile_bottom",
            "label": "Mobile Margin Bottom",
            "default": 0
        },
        {
            "type": "number",
            "id": "Mobile_paddingBottom",
            "label": "Mobile Padding Bottom",
            "default": 0
        }
    ],
    "blocks": [
        {
            "type": "block-item",
            "name": "Block Item",
            "settings": [
                {
                    "type": "header",
                    "content": "Media Settings"
                },
                {
                    "type": "image_picker",
                    "id": "pc_image",
                    "label": "Image"
                },
                {
                    "type": "video",
                    "id": "video",
                    "label": "Video"
                },
                {
                    "type": "product",
                    "id": "product",
                    "label": "product"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "index-positive-reviews"
        }
    ]
}
{% endschema %}
