{% doc %}
  @prompt
    Create a responsive campaign timeline section for Shopify.
    
    Content:
    
    - Apr 29: VIP 22% OFF coupon released
    
    - Apr 30: Mid-Year Surprise Drop begins
    
    - May 7: VIP 25% OFF coupon released
    
    - May 20: Campaign ends
    
    Design:
    
    - Desktop: horizontal timeline.
    
    - Mobile: vertical stacked timeline.
    
    - Use rounded cards, clear dates, short descriptions, and playful visual details.
    
    - Include customizable timeline items in the schema.
    
    - Must match theme container width and work perfectly on mobile., 竖着的时间轴, 鼠标悬浮在卡片上时这个时间轴节点的小圆点能一起展示动效。动效的3D效果更明显一些。, 小圆点的效果过了，稍微简单一点。
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-vertical-timeline-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_mobile }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-vertical-timeline__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-vertical-timeline__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size_mobile }}px;
  }

  .ai-vertical-timeline__items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_gap_mobile }}px;
    position: relative;
  }

  .ai-vertical-timeline__item-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.connector_gap }}px;
    position: relative;
  }

  .ai-vertical-timeline__connector-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 4px;
  }

  .ai-vertical-timeline__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: {{ block.settings.dot_border_width }}px solid {{ block.settings.dot_border_color }};
    flex-shrink: 0;
    z-index: 2;
    box-shadow: 0 2px 8px rgba(63, 114, 229, 0.2);
    transition: all 0.3s ease;
  }

  .ai-vertical-timeline__line-{{ ai_gen_id }} {
    width: {{ block.settings.line_width }}px;
    flex-grow: 1;
    background-color: {{ block.settings.line_color }};
    margin-top: 8px;
    transition: all 0.3s ease;
  }

  .ai-vertical-timeline__item-{{ ai_gen_id }}:last-child .ai-vertical-timeline__line-{{ ai_gen_id }} {
    display: none;
  }

  .ai-vertical-timeline__card-{{ ai_gen_id }} {
    flex-grow: 1;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding_mobile }}px;
    {% if block.settings.card_shadow %}
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    {% endif %}
    {% if block.settings.card_border %}
      border: 1px solid {{ block.settings.card_border_color }};
    {% endif %}
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-vertical-timeline__card-{{ ai_gen_id }}:hover {
    {% if block.settings.card_shadow %}
      box-shadow: 0 8px 24px rgba(63, 114, 229, 0.15);
    {% endif %}
    transform: translateX(8px);
  }

  .ai-vertical-timeline__item-{{ ai_gen_id }}:hover .ai-vertical-timeline__dot-{{ ai_gen_id }} {
    transform: scale(1.2);
    box-shadow: 0 4px 16px rgba(63, 114, 229, 0.4);
  }

  .ai-vertical-timeline__item-{{ ai_gen_id }}:hover .ai-vertical-timeline__line-{{ ai_gen_id }} {
    background-color: {{ block.settings.dot_color }};
  }

  .ai-vertical-timeline__date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_size_mobile }}px;
    font-weight: 700;
    color: {{ block.settings.date_color }};
    margin-bottom: 8px;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }

  .ai-vertical-timeline__card-{{ ai_gen_id }}:hover .ai-vertical-timeline__date-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-vertical-timeline__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_mobile }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin-bottom: 6px;
    line-height: 1.4;
    transition: all 0.3s ease;
  }

  .ai-vertical-timeline__card-{{ ai_gen_id }}:hover .ai-vertical-timeline__title-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-vertical-timeline__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size_mobile }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    transition: all 0.3s ease;
  }

  .ai-vertical-timeline__card-{{ ai_gen_id }}:hover .ai-vertical-timeline__description-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  @media screen and (min-width: 750px) {
    .ai-vertical-timeline-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 40px;
    }

    .ai-vertical-timeline__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_desktop }}px;
      margin-bottom: 60px;
    }

    .ai-vertical-timeline__items-{{ ai_gen_id }} {
      gap: {{ block.settings.item_gap_desktop }}px;
    }

    .ai-vertical-timeline__card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_desktop }}px;
    }

    .ai-vertical-timeline__card-{{ ai_gen_id }}:hover {
      transform: translateX(12px);
    }

    .ai-vertical-timeline__date-{{ ai_gen_id }} {
      font-size: {{ block.settings.date_size_desktop }}px;
    }

    .ai-vertical-timeline__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_desktop }}px;
    }

    .ai-vertical-timeline__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_desktop }}px;
    }
  }
{% endstyle %}

