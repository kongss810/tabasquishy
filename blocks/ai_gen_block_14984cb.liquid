{% doc %}
  @prompt
    Create a responsive coupon claim section for my Shopify store.
    
    Section purpose:
    A promotional coupon module where customers can clearly see available coupon offers and click a button to copy or claim the coupon code.
    
    Design requirements:
    - Fully responsive for both desktop and mobile.
    - Perfectly align with the theme’s standard page width and side margins.
    - Do not exceed the main content container width.
    - On desktop, use a clean card/grid layout with 2–3 coupon cards per row depending on screen width.
    - On mobile, stack coupon cards vertically with comfortable spacing.
    - Keep all text readable on small screens.
    - Use flexible spacing, not fixed pixel-heavy layout.
    - Use max-width, padding, and margin auto so it fits the theme naturally.
    - Avoid horizontal scrolling on mobile.
    - The design should look polished, soft, playful, and suitable for a cute sensory toy brand.
    
    Content:
    Section heading:
    
    Section subtitle:
    
    Coupon cards:
    1. 可设置
    
    2. 可设置
    
    可增加至多总共3个优惠券Code
    
    Card design:
    - Rounded corners.
    - Soft shadow or subtle border.
    - Light, cheerful background.
    - Clear offer text as the visual focus.
    - Coupon code displayed inside a dashed or highlighted code box.
    - Button text: Copy Code
    - Button should be full width on mobile and auto width or full card width on desktop.
    - Add hover effect on desktop.
    - Keep the module clean and not too crowded.
    
    Functionality:
    - When the customer clicks “Copy Code”, copy the coupon code to the clipboard.
    - After clicking, change the button text temporarily to “Copied!”
    - Make sure the JavaScript works independently within this section.
    - Do not break other theme scripts.
    - Use semantic HTML and accessible buttons.
    - Include customizable settings in the schema:
      - Section heading
      - Section subtitle
      - Coupon title
      - Coupon code
      - Coupon offer
      - Coupon description
      - Button text
      - Background color
      - Text color
      - Card background color
      - Button color
      - Button text color
      - Top and bottom padding
      - Maximum content width
    
    Spacing:
    - Desktop left and right spacing should match the Shopify theme page container.
    - Mobile side padding should be around 16px–20px.
    - Desktop section padding should feel spacious but not oversized.
    - Cards should have consistent gap spacing.
    
    Please generate a complete Shopify Liquid section file with HTML, CSS, JavaScript, and schema.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-coupon-section-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-coupon-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    width: 100%;
  }

  .ai-coupon-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-coupon-heading-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .ai-coupon-subtitle-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
    line-height: 1.5;
  }

  .ai-coupon-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    width: 100%;
  }

  .ai-coupon-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-coupon-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  .ai-coupon-offer-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-coupon-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    margin: 0;
    opacity: 0.9;
  }

  .ai-coupon-description-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    margin: 0;
    opacity: 0.7;
    line-height: 1.5;
  }

  .ai-coupon-code-box-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border: 2px dashed {{ block.settings.text_color }};
    border-radius: 8px;
    padding: 12px 16px;
    text-align: center;
    opacity: 0.3;
  }

  .ai-coupon-code-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    letter-spacing: 1px;
    font-family: monospace;
  }

  .ai-coupon-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: none;
  }

  .ai-coupon-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: scale(1.02);
  }

  .ai-coupon-button-{{ ai_gen_id }}:active {
    transform: scale(0.98);
  }

  .ai-coupon-button-{{ ai_gen_id }}.copied {
    background-color: #4caf50;
  }

  @media screen and (max-width: 749px) {
    .ai-coupon-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px 16px {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-coupon-heading-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-coupon-subtitle-{{ ai_gen_id }} {
      font-size: 14px;
    }

    .ai-coupon-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .ai-coupon-offer-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ai-coupon-code-{{ ai_gen_id }} {
      font-size: 16px;
    }

    .ai-coupon-button-{{ ai_gen_id }} {
      padding: 12px 20px;
      font-size: 15px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ai-coupon-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .ai-coupon-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }
{% endstyle %}

<coupon-claim-{{ ai_gen_id }} class="ai-coupon-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-coupon-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subtitle != blank %}
      <div class="ai-coupon-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-coupon-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-coupon-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-coupon-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign coupon_enabled_key = 'coupon_' | append: i | append: '_enabled'
          assign coupon_title_key = 'coupon_' | append: i | append: '_title'
          assign coupon_offer_key = 'coupon_' | append: i | append: '_offer'
          assign coupon_code_key = 'coupon_' | append: i | append: '_code'
          assign coupon_description_key = 'coupon_' | append: i | append: '_description'

          assign coupon_enabled = block.settings[coupon_enabled_key]
          assign coupon_title = block.settings[coupon_title_key]
          assign coupon_offer = block.settings[coupon_offer_key]
          assign coupon_code = block.settings[coupon_code_key]
          assign coupon_description = block.settings[coupon_description_key]
        %}

        {% if coupon_enabled %}
          <div class="ai-coupon-card-{{ ai_gen_id }}">
            {% if coupon_offer != blank %}
              <h3 class="ai-coupon-offer-{{ ai_gen_id }}">{{ coupon_offer }}</h3>
            {% endif %}

            {% if coupon_title != blank %}
              <p class="ai-coupon-title-{{ ai_gen_id }}">{{ coupon_title }}</p>
            {% endif %}

            {% if coupon_description != blank %}
              <p class="ai-coupon-description-{{ ai_gen_id }}">{{ coupon_description }}</p>
            {% endif %}

            {% if coupon_code != blank %}
              <div class="ai-coupon-code-box-{{ ai_gen_id }}">
                <span class="ai-coupon-code-{{ ai_gen_id }}">{{ coupon_code }}</span>
              </div>

              <button
                class="ai-coupon-button-{{ ai_gen_id }}"
                data-coupon-code="{{ coupon_code }}"
                aria-label="Copy coupon code {{ coupon_code }}"
              >
                {{ block.settings.button_text }}
              </button>
            {% else %}
              <div class="ai-coupon-code-box-{{ ai_gen_id }}">
                <span class="ai-coupon-code-{{ ai_gen_id }}">CODE</span>
              </div>
              <button class="ai-coupon-button-{{ ai_gen_id }}" disabled>
                {{ block.settings.button_text }}
              </button>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</coupon-claim-{{ ai_gen_id }}>

<script>
  (function() {
    class CouponClaim{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-coupon-button-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.buttons.forEach((button) => {
          button.addEventListener('click', (event) => {
            const couponCode = event.target.getAttribute('data-coupon-code');
            if (!couponCode) return;

            this.copyToClipboard(couponCode, event.target);
          });
        });
      }

      copyToClipboard(text, button) {
        const originalText = button.textContent;

        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(() => {
            this.showCopiedState(button, originalText);
          }).catch(() => {
            this.fallbackCopy(text, button, originalText);
          });
        } else {
          this.fallbackCopy(text, button, originalText);
        }
      }

      fallbackCopy(text, button, originalText) {
        const textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.style.position = 'fixed';
        textArea.style.left = '-9999px';
        document.body.appendChild(textArea);
        textArea.focus();
        textArea.select();

        try {
          document.execCommand('copy');
          this.showCopiedState(button, originalText);
        } catch (err) {
          console.error('Failed to copy:', err);
        }

        document.body.removeChild(textArea);
      }

      showCopiedState(button, originalText) {
        button.textContent = 'Copied!';
        button.classList.add('copied');

        setTimeout(() => {
          button.textContent = originalText;
          button.classList.remove('copied');
        }, 2000);
      }
    }

    customElements.define('coupon-claim-{{ ai_gen_id }}', CouponClaim{{ ai_gen_id }});
  })();
</script>

