{% doc %}
  @prompt
    Create a responsive Shopify sale rules section with clean expandable FAQ accordions.
    
    Content should explain:
    1. Coupon codes cannot be combined with other discounts.
    2. Each coupon can be used once per customer.
    3. Some offers are only available to eligible customer groups.
    4. Gift cards and selected special promotion items may be excluded.
    5. Customers can contact customer support if they are unsure whether an item qualifies.
    
    Design requirements:
    Use soft rounded accordion cards, mobile-first layout, readable spacing, theme-matching max width, and customizable heading, text, colors, spacing, and FAQ items in the schema.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sale-rules-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-sale-rules-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-sale-rules-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-sale-rules-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    font-weight: 600;
  }

  .ai-sale-rules-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-sale-rules-accordion-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.accordion_spacing }}px;
  }

  .ai-sale-rules-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    border: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-sale-rules-question-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.card_padding }}px;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: background-color 0.2s ease;
  }

  .ai-sale-rules-question-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.card_hover_background }};
  }

  .ai-sale-rules-question-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_size }}px;
    color: {{ block.settings.question_color }};
    font-weight: 600;
    margin: 0;
    flex: 1;
  }

  .ai-sale-rules-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: {{ block.settings.icon_color }};
  }

  .ai-sale-rules-item-{{ ai_gen_id }}.active .ai-sale-rules-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-sale-rules-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .ai-sale-rules-item-{{ ai_gen_id }}.active .ai-sale-rules-answer-{{ ai_gen_id }} {
    max-height: 500px;
    padding: 0 {{ block.settings.card_padding }}px {{ block.settings.card_padding }}px;
  }

  .ai-sale-rules-answer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_size }}px;
    color: {{ block.settings.answer_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-sale-rules-{{ ai_gen_id }} {
      padding: 30px 16px;
    }

    .ai-sale-rules-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-sale-rules-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-sale-rules-question-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.question_size }}px * 0.9);
    }

    .ai-sale-rules-answer-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.answer_size }}px * 0.9);
    }
  }
{% endstyle %}

<sale-rules-accordion-{{ ai_gen_id }} class="ai-sale-rules-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-sale-rules-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-sale-rules-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-sale-rules-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <div class="ai-sale-rules-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-sale-rules-accordion-{{ ai_gen_id }}">
      {% if block.settings.faq_1_question != blank %}
        <div class="ai-sale-rules-item-{{ ai_gen_id }}" data-index="1">
          <button
            class="ai-sale-rules-question-{{ ai_gen_id }}"
            aria-expanded="false"
            aria-controls="ai-sale-rules-answer-1-{{ ai_gen_id }}"
          >
            <h3 class="ai-sale-rules-question-text-{{ ai_gen_id }}">{{ block.settings.faq_1_question }}</h3>
            <svg class="ai-sale-rules-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="ai-sale-rules-answer-{{ ai_gen_id }}" id="ai-sale-rules-answer-1-{{ ai_gen_id }}">
            <div class="ai-sale-rules-answer-text-{{ ai_gen_id }}">{{ block.settings.faq_1_answer }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.faq_2_question != blank %}
        <div class="ai-sale-rules-item-{{ ai_gen_id }}" data-index="2">
          <button
            class="ai-sale-rules-question-{{ ai_gen_id }}"
            aria-expanded="false"
            aria-controls="ai-sale-rules-answer-2-{{ ai_gen_id }}"
          >
            <h3 class="ai-sale-rules-question-text-{{ ai_gen_id }}">{{ block.settings.faq_2_question }}</h3>
            <svg class="ai-sale-rules-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="ai-sale-rules-answer-{{ ai_gen_id }}" id="ai-sale-rules-answer-2-{{ ai_gen_id }}">
            <div class="ai-sale-rules-answer-text-{{ ai_gen_id }}">{{ block.settings.faq_2_answer }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.faq_3_question != blank %}
        <div class="ai-sale-rules-item-{{ ai_gen_id }}" data-index="3">
          <button
            class="ai-sale-rules-question-{{ ai_gen_id }}"
            aria-expanded="false"
            aria-controls="ai-sale-rules-answer-3-{{ ai_gen_id }}"
          >
            <h3 class="ai-sale-rules-question-text-{{ ai_gen_id }}">{{ block.settings.faq_3_question }}</h3>
            <svg class="ai-sale-rules-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="ai-sale-rules-answer-{{ ai_gen_id }}" id="ai-sale-rules-answer-3-{{ ai_gen_id }}">
            <div class="ai-sale-rules-answer-text-{{ ai_gen_id }}">{{ block.settings.faq_3_answer }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.faq_4_question != blank %}
        <div class="ai-sale-rules-item-{{ ai_gen_id }}" data-index="4">
          <button
            class="ai-sale-rules-question-{{ ai_gen_id }}"
            aria-expanded="false"
            aria-controls="ai-sale-rules-answer-4-{{ ai_gen_id }}"
          >
            <h3 class="ai-sale-rules-question-text-{{ ai_gen_id }}">{{ block.settings.faq_4_question }}</h3>
            <svg class="ai-sale-rules-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="ai-sale-rules-answer-{{ ai_gen_id }}" id="ai-sale-rules-answer-4-{{ ai_gen_id }}">
            <div class="ai-sale-rules-answer-text-{{ ai_gen_id }}">{{ block.settings.faq_4_answer }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.faq_5_question != blank %}
        <div class="ai-sale-rules-item-{{ ai_gen_id }}" data-index="5">
          <button
            class="ai-sale-rules-question-{{ ai_gen_id }}"
            aria-expanded="false"
            aria-controls="ai-sale-rules-answer-5-{{ ai_gen_id }}"
          >
            <h3 class="ai-sale-rules-question-text-{{ ai_gen_id }}">{{ block.settings.faq_5_question }}</h3>
            <svg class="ai-sale-rules-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="ai-sale-rules-answer-{{ ai_gen_id }}" id="ai-sale-rules-answer-5-{{ ai_gen_id }}">
            <div class="ai-sale-rules-answer-text-{{ ai_gen_id }}">{{ block.settings.faq_5_answer }}</div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</sale-rules-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class SaleRulesAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-sale-rules-item-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const button = item.querySelector('.ai-sale-rules-question-{{ ai_gen_id }}');
          
          button.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            
            if (isActive) {
              item.classList.remove('active');
              button.setAttribute('aria-expanded', 'false');
            } else {
              item.classList.add('active');
              button.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    }

    customElements.define('sale-rules-accordion-{{ ai_gen_id }}', SaleRulesAccordion{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Sale rules FAQ",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sale Rules & Terms"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Please review our sale terms and conditions below"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "FAQ items"
    },
    {
      "type": "text",
      "id": "faq_1_question",
      "label": "Question 1",
      "default": "Can I combine coupon codes with other discounts?"
    },
    {
      "type": "textarea",
      "id": "faq_1_answer",
      "label": "Answer 1",
      "default": "No, coupon codes cannot be combined with other discounts or promotional offers. Only one discount code can be applied per order."
    },
    {
      "type": "text",
      "id": "faq_2_question",
      "label": "Question 2",
      "default": "How many times can I use a coupon code?"
    },
    {
      "type": "textarea",
      "id": "faq_2_answer",
      "label": "Answer 2",
      "default": "Each coupon code can be used once per customer. Once you've used a code, it cannot be reused on future orders."
    },
    {
      "type": "text",
      "id": "faq_3_question",
      "label": "Question 3",
      "default": "Are all customers eligible for promotional offers?"
    },
    {
      "type": "textarea",
      "id": "faq_3_answer",
      "label": "Answer 3",
      "default": "Some offers are only available to eligible customer groups. Check the specific promotion details to see if you qualify."
    },
    {
      "type": "text",
      "id": "faq_4_question",
      "label": "Question 4",
      "default": "Are there any excluded items?"
    },
    {
      "type": "textarea",
      "id": "faq_4_answer",
      "label": "Answer 4",
      "default": "Yes, gift cards and selected special promotion items may be excluded from certain offers. Please check the promotion terms for details."
    },
    {
      "type": "text",
      "id": "faq_5_question",
      "label": "Question 5",
      "default": "What if I'm unsure whether an item qualifies?"
    },
    {
      "type": "textarea",
      "id": "faq_5_answer",
      "label": "Answer 5",
      "default": "If you're unsure whether an item qualifies for a promotion, please contact our customer support team and we'll be happy to help."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Header spacing",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "subheading_spacing",
      "label": "Subheading spacing",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "accordion_spacing",
