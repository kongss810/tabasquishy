{% doc %}
  @prompt
    Create a responsive Shopify “Why Tabasquishy” section.
    
    Purpose:
    Explain the brand’s key differences in a clear and premium way.
    
    Heading:
    Why Tabasquishy® Feels Different
    
    Feature cards:
    1. Soft Emotional Relief
    Description: Made to be pressed, stretched, and held whenever your mood needs a tiny reset.
    
    2. Original Character-Led Design
    Description: We turn feelings, trends, and everyday joy into collectible squishy characters.
    
    3. Satisfying Silicone Texture
    Description: Soft, slow-rebounding, and made for a deeply satisfying sensory experience.
    
    4. Collectible & Giftable
    Description: Cute, expressive, and easy to love — perfect for collecting, gifting, and sharing.
    
    Design requirements:
    - Desktop: 4 cards in one row or 2x2 grid.
    - Tablet: 2 cards per row.
    - Mobile: stacked cards.
    - Use icons or small image placeholders for each feature.
    - Rounded cards, soft shadow, subtle hover effect.
    - Fully responsive and aligned with theme container margins.
    - Include customizable heading, feature title, description, icon/image, colors, spacing, and card style in schema.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-why-tabasquishy-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_mobile }}px 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-why-tabasquishy-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 40px;
    }
  }

  .ai-why-tabasquishy__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-why-tabasquishy__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_desktop }}px;
    }
  }

  .ai-why-tabasquishy__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.card_gap_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-why-tabasquishy__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.card_gap_desktop }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .ai-why-tabasquishy__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.desktop_columns }}, 1fr);
    }
  }

  .ai-why-tabasquishy__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.card_alignment }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    {% if block.settings.card_shadow %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    {% endif %}
    {% if block.settings.card_border %}
      border: 1px solid {{ block.settings.card_border_color }};
    {% endif %}
  }

  .ai-why-tabasquishy__card-{{ ai_gen_id }}:hover {
    {% if block.settings.enable_hover_effect %}
      transform: translateY(-4px);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
    {% endif %}
  }

  .ai-why-tabasquishy__icon-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.icon_spacing }}px;
    display: flex;
    justify-content: {{ block.settings.card_alignment }};
    align-items: center;
  }

  .ai-why-tabasquishy__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    object-fit: contain;
  }

  .ai-why-tabasquishy__icon-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    background-color: {{ block.settings.icon_placeholder_bg }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-why-tabasquishy__icon-placeholder-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    color: {{ block.settings.icon_placeholder_color }};
  }

  .ai-why-tabasquishy__card-title-{{ ai_gen_id }} {
    color: {{ block.settings.card_title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
  }

  .ai-why-tabasquishy__card-description-{{ ai_gen_id }} {
    color: {{ block.settings.card_description_color }};
    margin: 0;
    font-size: {{ block.settings.card_description_size }}px;
    line-height: 1.6;
  }
{% endstyle %}

<why-tabasquishy-{{ ai_gen_id }} class="ai-why-tabasquishy-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-why-tabasquishy__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-why-tabasquishy__grid-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign title_key = 'feature_' | append: i | append: '_title'
        assign description_key = 'feature_' | append: i | append: '_description'
        assign icon_key = 'feature_' | append: i | append: '_icon'
        
        assign feature_title = block.settings[title_key]
        assign feature_description = block.settings[description_key]
        assign feature_icon = block.settings[icon_key]
      %}

      {% if feature_title != blank or feature_description != blank %}
        <div class="ai-why-tabasquishy__card-{{ ai_gen_id }}">
          <div class="ai-why-tabasquishy__icon-wrapper-{{ ai_gen_id }}">
            {% if feature_icon %}
              <img
                src="{{ feature_icon | image_url: width: 200 }}"
                alt="{{ feature_title | escape }}"
                class="ai-why-tabasquishy__icon-{{ ai_gen_id }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <div class="ai-why-tabasquishy__icon-placeholder-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
            {% endif %}
          </div>

          {% if feature_title != blank %}
            <h3 class="ai-why-tabasquishy__card-title-{{ ai_gen_id }}">{{ feature_title }}</h3>
          {% endif %}

          {% if feature_description != blank %}
            <p class="ai-why-tabasquishy__card-description-{{ ai_gen_id }}">{{ feature_description }}</p>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</why-tabasquishy-{{ ai_gen_id }}>

<script>
  (function() {
    class WhyTabasquishy{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-why-tabasquishy__card-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.cards.forEach((card) => {
          card.setAttribute('role', 'article');
        });
      }
    }

    customElements.define('why-tabasquishy-{{ ai_gen_id }}', WhyTabasquishy{{ ai_gen_id }});
  })();
</script>

