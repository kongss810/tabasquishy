                        </g>
                    </svg>
                {%- else -%}
                    {{ cart.item_count }}
                {%- endif -%}
            </span>
        </div>
    </a>

    {%- render 'localization2', id: 'HeaderLocalization', show_language_switcher: show_language_switcher, show_currency_switcher: show_currency_switcher -%}
</div>
